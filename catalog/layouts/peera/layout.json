{
  "version": "1.1.1",
  "name": "Peera Default",
  "description": "Final production alignment. 100% Schema-Live. Auth/Admin pages restored.",
  "layout": {
    "header": {
      "container_class": "sticky top-0 z-99999 flex w-full border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-900 lg:border-b h-16 lg:h-[72px]",
      "html": "<div class='flex items-center justify-between w-full lg:px-6'><div class='flex items-center justify-between w-full gap-2 px-3 py-3 border-b border-gray-200 dark:border-gray-800 sm:gap-4 lg:justify-normal lg:border-b-0 lg:px-0 lg:py-4'><button onclick='Peera.sidebar.toggle()' class='flex items-center justify-center w-10 h-10 text-gray-500 border-gray-200 rounded-lg z-99999 dark:border-gray-800 lg:hidden dark:text-gray-400'><svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><line x1='3' y1='12' x2='21' y2='12'/><line x1='3' y1='6' x2='21' y2='6'/><line x1='3' y1='18' x2='21' y2='18'/></svg></button></div><div class='hidden items-center justify-between w-full gap-4 px-5 py-4 lg:flex lg:justify-end lg:px-0'><div class='flex items-center gap-2'><span class='hidden rounded-full border border-blue-200 bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700 lg:inline-flex'>{{global.customer_status}}</span></div><div class='flex items-center gap-2 2xsm:gap-3'><div class='hidden lg:flex items-center gap-2 rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 px-3 py-2 text-xs font-medium text-gray-600 dark:text-gray-300'><span>Language</span><select class='bg-transparent text-xs font-medium outline-none cursor-pointer border-none'><option>English</option><option>Indonesian</option></select></div><button onclick='Peera.theme.toggle()' class='relative flex h-11 w-11 items-center justify-center rounded-full border border-gray-200 bg-white text-gray-500 transition-colors hover:bg-gray-100 dark:border-gray-800 dark:bg-gray-900 dark:text-gray-400 dark:hover:bg-gray-800'><svg class='dark:hidden block' width='20' height='20' viewBox='0 0 20 20' fill='none' stroke='currentColor' stroke-width='2'><path d='M10 15a5 5 0 100-10 5 5 0 000 10zM10 2v1M10 18v1M4.22 4.22l.71.71M15.07 15.07l.71.71M2 10h1M18 10h1M4.22 15.78l.71-.71M15.07 4.93l.71-.71'/></svg><svg class='hidden dark:block text-yellow-400' width='20' height='20' viewBox='0 0 20 20' fill='none' stroke='currentColor' stroke-width='2'><path d='M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z'/></svg></button><button class='relative flex h-11 w-11 items-center justify-center rounded-full border border-gray-200 bg-white text-gray-500 transition-colors hover:bg-gray-100 dark:border-gray-800 dark:bg-gray-900 dark:text-gray-400 dark:hover:bg-gray-800'><svg width='20' height='20' fill='currentColor' viewBox='0 0 20 20'><path fill-rule='evenodd' clip-rule='evenodd' d='M10.75 2.29248C10.75 1.87827 10.4143 1.54248 10 1.54248C9.58583 1.54248 9.25004 1.87827 9.25004 2.29248V2.83613C6.08266 3.20733 3.62504 5.9004 3.62504 9.16748V14.4591H3.33337C2.91916 14.4591 2.58337 14.7949 2.58337 15.2091C2.58337 15.6234 2.91916 15.9591 3.33337 15.9591H4.37504H15.625H16.6667C17.0809 15.9591 17.4167 15.6234 17.4167 15.2091C17.4167 14.7949 17.0809 14.4591 16.6667 14.4591H16.375V9.16748C16.375 5.9004 13.9174 3.20733 10.75 2.83613V2.29248ZM14.875 14.4591V9.16748C14.875 6.47509 12.6924 4.29248 10 4.29248C7.30765 4.29248 5.12504 6.47509 5.12504 9.16748V14.4591H14.875ZM8.00004 17.7085C8.00004 18.1228 8.33583 18.4585 8.75004 18.4585H11.25C11.6643 18.4585 12 18.1228 12 17.7085C12 17.2943 11.6643 16.9585 11.25 16.9585H8.75004C8.33583 16.9585 8.00004 17.2943 8.00004 17.7085Z' /></svg><div class='absolute top-2.5 right-2.5 w-2.5 h-2.5 bg-red-500 rounded-full border-2 border-white dark:border-gray-900'></div></button><div class='relative'><button class='flex items-center text-gray-700 dark:text-gray-400'><span class='mr-3 flex h-11 w-11 items-center justify-center rounded-full bg-brand-100 text-sm font-semibold text-brand-700'>{{global.customer_status[0]}}</span><span class='block mr-1 font-medium text-theme-sm text-gray-900 dark:text-white'>{{profile.fullname}}</span><svg class='stroke-gray-500 dark:stroke-gray-400 transition-transform duration-200' width='18' height='20' viewBox='0 0 18 20' fill='none'><path d='M4.3125 8.65625L9 13.3437L13.6875 8.65625' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/></svg></button></div></div></div></div>"
    },
    "nav": {
      "container_class": "fixed top-16 left-0 z-50 flex h-[calc(100dvh-4rem)] flex-col overflow-hidden border-r border-gray-200 bg-white px-5 text-gray-900 transition-all duration-300 ease-in-out dark:border-gray-800 dark:bg-gray-900 lg:top-0 lg:h-screen w-[260px] lg:translate-x-0 lg:flex",
      "header_html": "<div class='py-8 flex justify-start'><div class='flex items-center gap-3'><img alt='Peera' width='50' height='50' src='{{global.logo}}'><div><p class='text-base font-semibold leading-tight text-gray-900 dark:text-white'>{{global.company_name}}</p><p class='text-xs leading-tight text-gray-500 dark:text-gray-400 uppercase tracking-tighter'>{{global.tenant_code}}</p></div></div></div>",
      "groups": [
        {
          "title": "OVERVIEW",
          "items": [
            { "id": "nav.dashboard", "label": "Dashboard", "url": "/", "html": "<li><a class='menu-item group menu-item-active' href='/'><svg class='size-5' width='1em' height='1em' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z'/><polyline points='9 22 9 12 15 12 15 22'/></svg>Dashboard</a></li>" }
          ]
        },
        {
          "title": "MANAGEMENT",
          "items": [
            { "id": "nav.status", "label": "Status", "url": "/status", "html": "<li><a class='menu-item group menu-item-inactive' href='/status'><svg class='size-5' width='1em' height='1em' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='22 12 18 12 15 21 9 3 6 12 2 12'/></svg>Status</a></li>" },
            { "id": "nav.billing", "label": "Billing", "url": "/billing", "html": "<li><a class='menu-item group menu-item-inactive' href='/billing'><svg class='size-5' width='1em' height='1em' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='2' y='5' width='20' height='14' rx='2' ry='2'/><line x1='2' y1='10' x2='22' y2='10'/></svg>Billing</a></li>" },
            { "id": "nav.documents", "label": "Documents", "url": "/documents", "html": "<li><a class='menu-item group menu-item-inactive' href='/documents'><svg class='size-5' width='1em' height='1em' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z'/><polyline points='14 2 14 8 20 8'/></svg>Documents</a></li>" },
            { "id": "nav.support", "label": "Support", "url": "/support", "html": "<li><a class='menu-item group menu-item-inactive' href='/support'><svg class='size-5' width='1em' height='1em' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z'/></svg>Support</a></li>" }
          ]
        },
        {
          "title": "ACCOUNT",
          "items": [
            { "id": "nav.profile", "label": "Profile", "url": "/profile", "html": "<li><a class='menu-item group menu-item-inactive' href='/profile'><svg class='size-5' width='1em' height='1em' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2'/><circle cx='12' cy='7' r='4'/></svg>Profile</a></li>" }
          ]
        }
      ],
      "footer_html": "<div class='mt-auto p-4 border-t border-gray-200 dark:border-gray-800'><button onclick='Peera.auth.logout()' class='w-full flex items-center gap-3 px-4 py-2.5 text-gray-600 dark:text-gray-400 hover:text-red-600 transition-colors text-sm font-medium'><svg class='size-5' width='1em' height='1em' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4'/><polyline points='16 17 21 12 16 7'/><line x1='21' y1='12' x2='9' y2='12'/></svg>Logout</button></div>"
    },
    "contents": {
      "login": { "title": "Portal Login", "html": "<div class='flex flex-col gap-8 max-w-sm mx-auto mt-20'><div class='flex flex-col gap-2 text-center'><h2 class='text-2xl font-bold text-gray-900 dark:text-white'>Portal Login</h2><p class='text-sm text-gray-500'>Welcome back to {{global.company_name}}</p></div><div class='flex flex-col gap-4'><div class='flex flex-col gap-1.5'><label class='text-xs font-semibold text-gray-600 dark:text-gray-400'>Email or ID</label><input id='login-identifier' type='text' placeholder='username@example.com' class='w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 transition-all dark:text-white' /></div><div class='flex flex-col gap-1.5'><div class='flex justify-between items-center'><label class='text-xs font-semibold text-gray-600 dark:text-gray-400'>Password</label><a href='{{functional.action_forgot_password}}' class='text-xs font-bold text-brand-600 hover:underline'>Forgot?</a></div><input id='login-password' type='password' placeholder='••••••••' class='w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 transition-all dark:text-white' /></div><button onclick='Peera.auth.login(\"login-identifier\", \"login-password\")' class='w-full py-4 bg-brand-500 hover:bg-brand-600 text-white rounded-xl font-bold text-sm shadow-lg shadow-brand-500/20 transition-all active:scale-95'>Sign In</button></div></div>" },
      "admin/login": { "title": "Admin Login", "html": "<div class='flex flex-col gap-8 max-w-sm mx-auto mt-20'><div class='flex flex-col gap-2 text-center'><h2 class='text-2xl font-bold text-gray-900 dark:text-white uppercase tracking-tighter'>Peera Admin</h2><p class='text-[10px] font-bold text-stone-500 uppercase tracking-widest'>Infrastructure Grid Access</p></div><div class='flex flex-col gap-4'><div class='flex flex-col gap-1.5'><label class='text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase'>Admin Identity</label><input id='admin-identifier' type='text' placeholder='root@peera.id' class='w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 transition-all dark:text-white' /></div><div class='flex flex-col gap-1.5'><label class='text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase'>Access Key</label><input id='admin-password' type='password' placeholder='••••••••' class='w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 transition-all dark:text-white' /></div><button onclick='Peera.auth.login(\"admin-identifier\", \"admin-password\")' class='w-full py-4 bg-gray-900 dark:bg-white dark:text-black text-white rounded-xl font-bold text-xs uppercase tracking-widest transition-all active:scale-95 shadow-xl'>Initialize Session</button></div></div>" },
      "dashboard": { "title": "Dashboard", "html": "<div class='flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Platform Dashboard</h2><div class='overflow-hidden rounded-3xl border border-slate-200 bg-[linear-gradient(135deg,_#0f172a_0%,_#111827_42%,_#1e293b_100%)] p-6 text-white shadow-lg'><div class='flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between'><div class='max-w-2xl'><span class='inline-flex rounded-full border border-white/15 bg-white/10 px-3 py-1 text-[10px] font-medium uppercase tracking-[0.24em] text-sky-100'>Sovereign Portal</span><h2 class='mt-3 text-2xl font-bold tracking-tight'>Greetings, {{global.customer_fullname}}</h2><p class='mt-2 text-sm leading-relaxed text-slate-300'>Access your secure ISP orchestration panel and monitoring artifacts.</p></div><div class='min-w-[220px] rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur-sm'><p class='text-[10px] font-bold uppercase tracking-[0.22em] text-slate-300'>Access Status</p><p class='mt-1.5 text-lg font-bold text-white'>{{global.customer_status}}</p></div></div></div><div class='grid grid-cols-1 gap-6 md:grid-cols-3'><div class='p-6 rounded-3xl border border-slate-200 bg-white dark:bg-gray-800 dark:border-gray-700 shadow-sm'><p class='text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500'>Plan</p><p class='mt-4 text-2xl font-bold tracking-tight text-slate-950 dark:text-white'>{{status.service_plan}}</p></div><div class='p-6 rounded-3xl border border-slate-200 bg-white dark:bg-gray-800 dark:border-gray-700 shadow-sm'><p class='text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500'>Obligation</p><p class='mt-4 text-2xl font-bold tracking-tight text-slate-950 dark:text-white tabular-nums'>{{global.currency}} {{billing.total_amount}}</p></div><div class='p-6 rounded-3xl border border-slate-200 bg-white dark:bg-gray-800 dark:border-gray-700 shadow-sm'><p class='text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500'>Link</p><p class='mt-4 text-2xl font-bold tracking-tight text-emerald-600'>{{status.status}}</p></div></div></div>" },
      "status": { "title": "Status", "html": "<div class='flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Network Status</h2><div class='bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-3xl p-8 grid grid-cols-2 gap-12 shadow-sm'><div class='flex flex-col gap-1'><span class='text-xs text-gray-500 font-bold uppercase'>Connection Status</span><span class='text-3xl font-bold text-emerald-600'>{{status.status}}</span></div><div class='flex flex-col gap-1'><span class='text-xs text-gray-500 font-bold uppercase'>Assigned IP</span><span class='text-2xl font-mono font-bold dark:text-white'>{{status.active_ip}}</span></div><div class='flex flex-col gap-1'><span class='text-xs text-gray-500 font-bold uppercase'>Readiness</span><span class='text-xl font-bold text-brand-600 uppercase'>{{status.is_online}}</span></div><div class='flex flex-col gap-1'><span class='text-xs text-gray-500 font-bold uppercase'>Service Plan</span><span class='text-xl font-bold dark:text-white uppercase'>{{status.service_plan}}</span></div></div></div>" },
      "billing": { "title": "Billing", "html": "<div class='flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Billing Ledger</h2><div class='grid grid-cols-12 gap-6'><div class='col-span-8 p-10 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-3xl shadow-sm flex flex-col gap-8'><div class='flex flex-col gap-1'><span class='text-xs text-gray-500 font-bold uppercase'>Total Outstanding</span><span class='text-6xl font-bold text-gray-900 dark:text-white tabular-nums tracking-tighter'>{{global.currency}} {{billing.total_amount}}</span></div><div class='grid grid-cols-3 gap-6 border-t border-gray-100 dark:border-gray-700 pt-6'><div class='flex flex-col'><span class='text-[10px] text-gray-400 font-bold uppercase'>Net</span><span class='text-sm font-bold dark:text-white'>{{global.currency}} {{billing.subtotal}}</span></div><div class='flex flex-col'><span class='text-[10px] text-gray-400 font-bold uppercase'>Tax</span><span class='text-sm font-bold dark:text-white'>{{global.currency}} {{billing.tax_amount}}</span></div><div class='flex flex-col'><span class='text-[10px] text-gray-400 font-bold uppercase'>Paid</span><span class='text-sm font-bold text-emerald-600'>{{global.currency}} {{billing.total_paid}}</span></div></div><a href='{{functional.action_pay_invoice}}' target='_blank' class='w-full py-4 bg-brand-500 hover:bg-brand-600 text-white rounded-xl text-center font-bold text-sm shadow-lg shadow-brand-500/20 transition-all'>Pay Now</a></div><div class='col-span-4 p-8 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-3xl flex flex-col gap-6'><span class='text-[10px] font-bold text-gray-500 uppercase'>Invoice Artifact</span><div class='flex flex-col gap-4'><div class='flex justify-between'><span class='text-xs text-gray-400 uppercase'>#ID</span><span class='text-sm font-bold dark:text-white'>{{billing.invoice_number}}</span></div><div class='flex justify-between'><span class='text-xs text-gray-400 uppercase'>Due</span><span class='text-sm font-bold text-red-600'>{{billing.due_date}}</span></div><div class='pt-4 border-t border-gray-200 dark:border-white/10 flex flex-col'><span class='text-[9px] text-gray-400 uppercase'>Service Window</span><p class='text-[10px] font-bold dark:text-white'>{{billing.period_start}} - {{billing.period_end}}</p></div></div></div></div></div>" },
      "support": { "title": "Support", "html": "<div class='flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Support Center</h2><div class='bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-3xl p-10 flex flex-col gap-8 shadow-sm'><div class='flex justify-between items-center'><div class='flex items-center gap-4'><span class='px-2.5 py-1 bg-brand-500 text-white rounded text-[10px] font-bold'>#{{support.ticket_number}}</span><h4 class='text-xl font-bold text-gray-900 dark:text-white uppercase'>{{support.title}}</h4></div><div class='text-indigo-600 text-[10px] font-bold uppercase tracking-widest'>{{support.status}}</div></div><p class='text-gray-500 text-base italic leading-relaxed'>\"{{support.description}}\"</p><div class='grid grid-cols-3 gap-10 pt-10 border-t border-gray-100 dark:border-gray-800'><div class='flex flex-col gap-1'><span class='text-[10px] text-gray-400 font-bold uppercase'>Priority</span><span class='text-sm font-bold text-amber-600 uppercase'>{{support.priority}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] text-gray-400 font-bold uppercase'>Created</span><span class='text-sm font-bold dark:text-white'>{{support.created_at}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] text-gray-400 font-bold uppercase'>Scheduled</span><span class='text-sm font-bold dark:text-white uppercase'>{{support.scheduled_at}}</span></div></div></div></div>" },
      "documents": { "title": "Documents", "html": "<div class='flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Digital Archive</h2><div class='grid grid-cols-1 md:grid-cols-2 gap-6'><div class='p-8 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm flex items-center justify-between group hover:border-brand-500/30 transition-all'><div class='flex items-center gap-6'><div class='w-14 h-14 bg-gray-50 dark:bg-gray-900 rounded-xl flex items-center justify-center text-gray-400 group-hover:text-brand-600 transition-colors'><svg width='28' height='28' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z'/><polyline points='14 2 14 8 20 8'/></svg></div><div class='flex flex-col gap-0.5'><span class='text-lg font-bold text-gray-900 dark:text-white uppercase tracking-tight'>{{documents.name}}</span><span class='text-[10px] text-gray-500 font-medium italic'>System Artifact &bull; PDF</span></div></div><a href='{{documents.file_url}}' target='_blank' class='px-6 py-2.5 bg-brand-500 hover:bg-brand-600 text-white rounded-xl text-xs font-bold shadow-lg transition-all'>Download</a></div></div></div>" },
      "profile": { "title": "Profile", "html": "<div class='flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Profile Settings</h2><div class='bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-3xl p-12 flex flex-col gap-12 shadow-sm'><div class='grid grid-cols-2 gap-20'><div class='flex flex-col gap-10'><div class='flex flex-col gap-1'><span class='text-[10px] text-gray-400 font-bold uppercase tracking-widest'>Legal Name</span><span class='text-3xl font-bold text-gray-900 dark:text-white'>{{profile.fullname}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] text-gray-400 font-bold uppercase tracking-widest'>Access ID</span><span class='text-2xl font-mono text-brand-600 font-bold'>{{profile.cust_id}}</span></div></div><div class='flex flex-col gap-10'><div class='flex flex-col gap-1'><span class='text-[10px] text-gray-400 font-bold uppercase tracking-widest'>Email Grid</span><span class='text-xl font-bold dark:text-white'>{{profile.email}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] text-gray-400 font-bold uppercase tracking-widest'>Auth Status</span><span class='text-xl font-bold text-emerald-600 uppercase tracking-widest italic'>{{profile.status}}</span></div></div></div><div class='pt-10 border-t border-gray-100 dark:border-gray-800 flex flex-col gap-2'><span class='text-[10px] text-gray-400 font-bold uppercase tracking-widest'>Installation Address</span><p class='text-xl font-medium text-gray-600 dark:text-gray-400 italic'>\"{{profile.address}}\"</p></div></div></div>" },
      "admin/theme": { "title": "Theme Architect", "html": "<div class='p-10 flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90 uppercase tracking-widest'>Theme Orchestration</h2><div class='p-20 border border-dashed border-gray-300 dark:border-gray-700 rounded-3xl text-center'><p class='text-gray-500 uppercase text-xs font-bold tracking-[0.5em]'>Aegis Obsidian UI Enabled</p></div></div>" }
    },
    "theme": { "tokens": { "colors": { "brand-500": "#465fff", "stone-950": "#0c0c0c", "stone-900": "#171717" } } }
  }
}
