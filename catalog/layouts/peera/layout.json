{
  "version": "1.0.0",
  "name": "Peera Default",
  "description": "Standard layout for all new tenants",
  "layout": {
    "nav": {
      "position": "left",
      "header_html": "<div class='p-6 pb-4 flex flex-col gap-4'><div class='inline-flex items-center gap-3'><div class='w-8 h-8 bg-brand-500 rounded-xl flex items-center justify-center shadow-lg shadow-brand-500/20'><img src='{{global.logo}}' alt='{{global.company_name}}' class='w-5 h-5 object-contain invert brightness-0' /></div><div class='flex flex-col'><span class='font-black text-stone-900 dark:text-white uppercase tracking-tighter text-xs'>{{global.company_name}}</span><span class='text-[8px] font-black text-brand-500 uppercase tracking-widest'>Portal</span></div></div><div class='h-px w-full bg-stone-100 dark:bg-white/5 mt-2'></div></div>",
      "footer_html": "<div class='p-6 pt-4'><div class='h-px w-full bg-stone-100 dark:bg-white/5 mb-4'></div><div class='flex flex-col gap-1'><p class='text-[8px] font-black text-stone-400 uppercase tracking-[0.2em]'>{{global.company_name}} &copy; 2026</p><p class='text-[7px] font-medium text-stone-500'>Powered by Peera System</p></div></div>",
      "items": [
        { "id": "nav.home", "label": "Dashboard", "url": "/" },
        { "id": "nav.status", "label": "Network Status", "url": "/status" },
        { "id": "nav.billing", "label": "Billing & Invoices", "url": "/billing" },
        { "id": "nav.docs", "label": "Documents", "url": "/documents" },
        { "id": "nav.profile", "label": "My Profile", "url": "/profile" },
        { 
          "id": "nav.signout", 
          "label": "Sign Out", 
          "html": "<div class='px-4 mt-6'><button onclick='Peera.auth.logout()' class='w-full bg-red-500/5 hover:bg-red-500 text-red-500 hover:text-white py-3 rounded-xl transition-all text-[10px] font-black uppercase tracking-widest cursor-pointer border border-red-500/10'>Sign Out</button></div>" 
        }
      ]
    },
    "signout": { "script": "auth.logout" },
    "contents": {
      "dashboard": { "title": "Overview", "html": "<div class='p-8 lg:p-12 max-w-7xl mx-auto flex flex-col gap-10'><div class='flex flex-col gap-2'><p class='text-brand-500 font-black uppercase tracking-[0.3em] text-[10px]'>Welcome back,</p><h1 class='text-4xl font-black text-stone-900 dark:text-white tracking-tighter'>{{global.customer_fullname}}</h1></div><div class='grid grid-cols-1 md:grid-cols-3 gap-6'><div class='p-8 bg-white dark:bg-[#0c0c0c] border border-stone-200 dark:border-white/10 rounded-xl shadow-2xl relative overflow-hidden group'><div class='absolute top-0 right-0 w-24 h-24 bg-brand-500/5 blur-2xl rounded-full'></div><div class='relative z-10'><p class='text-stone-500 text-[10px] font-black uppercase tracking-[0.2em] mb-6 flex items-center gap-2'><span class='w-1.5 h-1.5 rounded-full bg-blue-500'></span> Network Status</p><h3 class='text-2xl font-black text-stone-950 dark:text-white mb-1'>{{status.status}}</h3><p class='text-xs text-stone-500 font-medium'>IP: {{status.active_ip}}</p></div></div><div class='p-8 bg-white dark:bg-[#0c0c0c] border border-stone-200 dark:border-white/10 rounded-xl shadow-2xl relative overflow-hidden group'><div class='relative z-10'><p class='text-stone-500 text-[10px] font-black uppercase tracking-[0.2em] mb-6 flex items-center gap-2'><span class='w-1.5 h-1.5 rounded-full bg-emerald-500'></span> Current Plan</p><h3 class='text-2xl font-black text-stone-950 dark:text-white mb-1'>{{status.service_plan}}</h3><p class='text-xs text-stone-500 font-medium'>Monthly Subscription</p></div></div><div class='p-8 bg-white dark:bg-[#0c0c0c] border border-stone-200 dark:border-white/10 rounded-xl shadow-2xl relative overflow-hidden group'><div class='relative z-10'><p class='text-stone-500 text-[10px] font-black uppercase tracking-[0.2em] mb-6 flex items-center gap-2'><span class='w-1.5 h-1.5 rounded-full bg-amber-500'></span> Outstanding</p><h3 class='text-2xl font-black text-stone-950 dark:text-white mb-1'>{{global.currency}} {{billing.total_amount}}</h3><p class='text-xs text-stone-500 font-medium italic'>Due in 5 days</p></div></div></div></div>" },
      "billing": { "title": "Billing", "html": "<div class='p-12 max-w-7xl mx-auto flex flex-col gap-12'><div class='flex flex-col gap-2'><h1 class='text-3xl font-black text-stone-900 dark:text-white tracking-tight'>Invoices & Payments</h1><p class='text-stone-500 font-medium'>Manage your billing history and settle unpaid invoices.</p></div><div class='bg-white dark:bg-[#0c0c0c] border border-stone-200 dark:border-white/10 rounded-xl shadow-3xl overflow-hidden'><div class='p-6 bg-stone-50 dark:bg-white/5 border-b border-stone-200 dark:border-white/5 flex justify-between items-center'><div class='flex flex-col'><span class='text-[10px] font-black uppercase tracking-widest text-stone-400'>Latest Invoice</span><span class='text-sm font-black dark:text-white'>#{{billing.invoice_number}}</span></div><div class='px-4 py-1.5 bg-amber-500/10 text-amber-500 rounded-lg text-[10px] font-black uppercase tracking-widest border border-amber-500/20'>{{billing.status}}</div></div><div class='p-10 flex flex-col gap-10'><div class='grid grid-cols-2 md:grid-cols-4 gap-8'><div class='flex flex-col gap-1'><span class='text-[9px] font-black text-stone-500 uppercase tracking-widest'>Date</span><span class='text-xs font-bold dark:text-stone-200'>{{billing.invoice_date}}</span></div><div class='flex flex-col gap-1'><span class='text-[9px] font-black text-stone-500 uppercase tracking-widest'>Due Date</span><span class='text-xs font-bold text-red-500'>{{billing.due_date}}</span></div><div class='flex flex-col gap-1'><span class='text-[9px] font-black text-stone-500 uppercase tracking-widest'>Tax ({{billing.tax_rate}}%)</span><span class='text-xs font-bold dark:text-stone-200'>{{global.currency}} {{billing.tax_amount}}</span></div><div class='flex flex-col gap-1'><span class='text-[9px] font-black text-stone-500 uppercase tracking-widest'>Total Amount</span><span class='text-xl font-black text-brand-500'>{{global.currency}} {{billing.total_amount}}</span></div></div><div class='flex gap-4 pt-4 border-t border-stone-100 dark:border-white/5'><button onclick='window.open(\"{{billing.payment_url}}\")' class='flex-1 py-4 bg-brand-500 hover:bg-brand-600 text-white rounded-xl text-xs font-black uppercase tracking-widest transition-all shadow-xl shadow-brand-500/20 active:scale-95 cursor-pointer'>Pay Now &rarr;</button><button class='px-8 py-4 bg-stone-100 dark:bg-white/5 text-stone-600 dark:text-white rounded-xl text-xs font-black uppercase tracking-widest hover:bg-stone-200 dark:hover:bg-white/10 transition-all cursor-pointer'>Download PDF</button></div></div></div></div>" },
      "status": { "title": "Status", "html": "<div class='p-12 max-w-7xl mx-auto flex flex-col gap-12'><div class='flex flex-col gap-2'><h1 class='text-3xl font-black text-stone-900 dark:text-white tracking-tight'>Network Performance</h1><p class='text-stone-500 font-medium'>Real-time infrastructure health and connection analytics.</p></div><div class='grid grid-cols-1 md:grid-cols-2 gap-8'><div class='p-10 bg-white dark:bg-[#0c0c0c] border border-stone-200 dark:border-white/10 rounded-xl shadow-2xl relative overflow-hidden'><div class='absolute top-0 left-0 w-full h-1.5 bg-emerald-500'></div><div class='flex flex-col gap-6 relative z-10'><div class='flex justify-between items-center'><h3 class='font-black text-stone-900 dark:text-white uppercase tracking-widest text-[10px]'>Service Status</h3><div class='flex items-center gap-2'><div class='w-2 h-2 bg-emerald-500 rounded-full animate-ping'></div><span class='text-[10px] font-black text-emerald-500 uppercase'>Active</span></div></div><div class='flex flex-col gap-1'><p class='text-4xl font-black text-stone-950 dark:text-white tracking-tight'>Operational</p><p class='text-xs text-stone-500 font-medium'>No incidents reported in the last 24 hours.</p></div></div></div><div class='p-10 bg-white dark:bg-[#0c0c0c] border border-stone-200 dark:border-white/10 rounded-xl shadow-2xl relative overflow-hidden'><div class='absolute top-0 left-0 w-full h-1.5 bg-blue-500'></div><div class='flex flex-col gap-6 relative z-10'><div class='flex justify-between items-center'><h3 class='font-black text-stone-900 dark:text-white uppercase tracking-widest text-[10px]'>Connectivity</h3><span class='text-[10px] font-black text-blue-500 uppercase'>{{status.active_ip}}</span></div><div class='flex flex-col gap-1'><p class='text-4xl font-black text-stone-950 dark:text-white tracking-tight'>{{status.service_plan}}</p><p class='text-xs text-stone-500 font-medium uppercase tracking-[0.2em]'>Fiber-to-the-Home Technology</p></div></div></div></div></div>" },
      "profile": { "title": "Profile", "html": "<div class='p-12 max-w-7xl mx-auto flex flex-col gap-12'><div class='flex justify-between items-end'><div class='flex flex-col gap-2'><h1 class='text-3xl font-black text-stone-900 dark:text-white tracking-tight'>Account Settings</h1><p class='text-stone-500 font-medium'>Manage your personal information and subscription plan.</p></div><button onclick='window.Peera.design.launch(\"/profile\")' class='px-6 py-2.5 bg-white dark:bg-white/5 border border-stone-200 dark:border-white/10 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-stone-50 dark:hover:bg-white/10 transition-all cursor-pointer shadow-xl shadow-black/5'>Edit Profile</button></div><div class='grid grid-cols-1 lg:grid-cols-3 gap-8'><div class='lg:col-span-2 flex flex-col gap-8'><div class='p-10 bg-white dark:bg-[#0c0c0c] border border-stone-200 dark:border-white/10 rounded-xl shadow-2xl flex flex-col gap-10'><h3 class='text-[10px] font-black uppercase tracking-[0.3em] text-stone-400'>Primary Information</h3><div class='grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8'><div class='flex flex-col gap-1.5'><span class='text-[9px] font-black text-stone-500 uppercase'>Full Name</span><span class='text-sm font-bold dark:text-white'>{{profile.fullname}}</span></div><div class='flex flex-col gap-1.5'><span class='text-[9px] font-black text-stone-500 uppercase'>Customer ID</span><span class='text-sm font-mono font-bold text-brand-500'>{{profile.cust_id}}</span></div><div class='flex flex-col gap-1.5'><span class='text-[9px] font-black text-stone-500 uppercase'>WhatsApp</span><span class='text-sm font-bold dark:text-white'>{{profile.whatsapp}}</span></div><div class='flex flex-col gap-1.5'><span class='text-[9px] font-black text-stone-500 uppercase'>Email Address</span><span class='text-sm font-bold dark:text-white'>{{profile.email}}</span></div></div><div class='h-px w-full bg-stone-100 dark:bg-white/5'></div><div class='flex flex-col gap-1.5'><span class='text-[9px] font-black text-stone-500 uppercase'>Installation Address</span><span class='text-sm font-bold dark:text-white leading-relaxed'>{{profile.address}}</span></div></div><div class='p-10 bg-white dark:bg-[#0c0c0c] border border-stone-200 dark:border-white/10 rounded-xl shadow-2xl flex flex-col gap-6'><h3 class='text-[10px] font-black uppercase tracking-[0.3em] text-stone-400'>Geographic Mapping</h3><div class='grid grid-cols-2 gap-8'><div class='p-6 bg-stone-50 dark:bg-white/5 rounded-xl border border-stone-100 dark:border-white/5'><span class='text-[8px] font-black text-stone-500 uppercase block mb-1'>Latitude</span><span class='text-xs font-mono font-bold dark:text-stone-300'>{{profile.latitude}}</span></div><div class='p-6 bg-stone-50 dark:bg-white/5 rounded-xl border border-stone-100 dark:border-white/5'><span class='text-[8px] font-black text-stone-500 uppercase block mb-1'>Longitude</span><span class='text-xs font-mono font-bold dark:text-stone-300'>{{profile.longitude}}</span></div></div></div></div><div class='flex flex-col gap-8'><div class='p-8 bg-brand-500 rounded-xl shadow-3xl shadow-brand-500/30 flex flex-col gap-6 relative overflow-hidden'><div class='absolute -bottom-10 -right-10 w-32 h-32 bg-white/10 blur-3xl rounded-full'></div><div class='flex flex-col gap-1 relative z-10'><span class='text-[9px] font-black text-white/60 uppercase tracking-widest'>Active Plan</span><h3 class='text-2xl font-black text-white tracking-tight'>{{profile.service_plan}}</h3></div><div class='flex items-center gap-2 px-3 py-1.5 bg-white/10 rounded-lg w-fit border border-white/10 relative z-10'><span class='text-[8px] font-black text-white uppercase tracking-widest'>{{profile.status}}</span></div></div><div class='p-8 bg-white dark:bg-[#0c0c0c] border border-stone-200 dark:border-white/10 rounded-xl shadow-2xl flex flex-col gap-6'><h3 class='text-[10px] font-black uppercase tracking-[0.3em] text-stone-400'>Coverage Region</h3><div class='flex items-center gap-3'><div class='w-10 h-10 bg-indigo-500/10 rounded-lg flex items-center justify-center text-indigo-500'><svg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z'/><circle cx='12' cy='10' r='3'/></svg></div><span class='text-sm font-bold dark:text-white'>{{profile.region}}</span></div></div></div></div></div>" },
      "documents": { "title": "Documents", "html": "<div class='p-12 max-w-7xl mx-auto flex flex-col gap-12'><div class='flex flex-col gap-2'><h1 class='text-3xl font-black text-stone-900 dark:text-white tracking-tight'>Digital Archive</h1><p class='text-stone-500 font-medium'>Access your contracts, legal terms, and service agreements.</p></div><div class='grid grid-cols-1 md:grid-cols-2 gap-6'><div class='p-6 bg-white dark:bg-[#0c0c0c] border border-stone-200 dark:border-white/10 rounded-xl shadow-2xl flex items-center justify-between group hover:border-brand-500/40 transition-all'><div class='flex items-center gap-5'><div class='w-14 h-14 bg-stone-100 dark:bg-white/5 rounded-xl flex items-center justify-center text-stone-400 group-hover:text-brand-500 transition-colors'><svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z'/><polyline points='14 2 14 8 20 8'/></svg></div><div class='flex flex-col gap-0.5'><span class='text-sm font-black dark:text-white uppercase tracking-tight'>{{documents.name}}</span><span class='text-[9px] font-black text-stone-500 uppercase tracking-widest'>PDF Document &bull; Verified</span></div></div><a href='{{documents.file_url}}' target='_blank' class='w-10 h-10 bg-brand-500/10 text-brand-500 rounded-lg flex items-center justify-center hover:bg-brand-500 hover:text-white transition-all'><svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v4'/><polyline points='7 10 12 15 17 10'/><line x1='12' x2='12' y1='15' y2='3'/></svg></a></div></div></div>" },
      "support": { "title": "Support", "html": "<div class='p-12 max-w-7xl mx-auto flex flex-col gap-12'><div class='flex justify-between items-end'><div class='flex flex-col gap-2'><h1 class='text-3xl font-black text-stone-900 dark:text-white tracking-tight'>Help Center</h1><p class='text-stone-500 font-medium'>Track your active support tickets or request technical assistance.</p></div><button onclick='window.Peera.design.launch(\"/support\")' class='px-6 py-3 bg-brand-500 hover:bg-brand-600 text-white rounded-xl text-xs font-black uppercase tracking-widest shadow-xl shadow-brand-500/20 active:scale-95 transition-all cursor-pointer'>Open New Ticket</button></div><div class='bg-white dark:bg-[#0c0c0c] border border-stone-200 dark:border-white/10 rounded-xl shadow-3xl overflow-hidden'><div class='p-6 bg-stone-50 dark:bg-white/5 border-b border-stone-200 dark:border-white/5'><h3 class='text-[10px] font-black uppercase tracking-widest text-stone-400'>Active Tickets</h3></div><div class='p-8'><div class='p-6 bg-stone-50 dark:bg-white/5 rounded-xl border border-stone-100 dark:border-white/5 flex justify-between items-start group hover:border-brand-500/20 transition-all'><div class='flex flex-col gap-3'><div class='flex items-center gap-3'><span class='px-2 py-0.5 bg-brand-500 text-white rounded text-[8px] font-black uppercase tracking-widest'>#{{support.ticket_number}}</span><h4 class='text-sm font-black dark:text-white uppercase tracking-tight'>{{support.title}}</h4></div><p class='text-xs text-stone-500 font-medium max-w-xl leading-relaxed'>{{support.description}}</p><div class='flex items-center gap-6 mt-2'><div class='flex flex-col gap-0.5'><span class='text-[8px] font-black text-stone-400 uppercase tracking-widest'>Created</span><span class='text-[10px] font-bold dark:text-stone-300'>{{support.created_at}}</span></div><div class='flex flex-col gap-0.5'><span class='text-[8px] font-black text-stone-400 uppercase tracking-widest'>Schedule</span><span class='text-[10px] font-bold text-blue-500'>{{support.scheduled_at}}</span></div></div></div><div class='px-4 py-1.5 bg-emerald-500/10 text-emerald-500 rounded-lg text-[9px] font-black uppercase tracking-widest border border-emerald-500/20'>{{support.status}}</div></div></div></div></div>" },
      "login": { "title": "Sign In", "html": "<div class='flex min-h-screen bg-stone-50 dark:bg-[#050505] font-sans overflow-hidden transition-colors duration-500 text-stone-900 dark:text-white relative'><div class='absolute inset-0 dark:hidden' style='background: radial-gradient(circle, transparent 20%, rgba(0,0,0,0.05) 100%); pointer-events: none;'></div><div class='w-full lg:w-[45%] flex flex-col justify-center items-center p-12 lg:p-20 z-20 bg-white dark:bg-[#050505] border-r border-stone-200 dark:border-white/5 shadow-2xl transition-all duration-500'><div class='w-full max-sm:px-4 max-w-sm relative'><button onclick='Peera.theme.toggle()' class='absolute -top-12 right-0 p-2 bg-stone-100 dark:bg-white/5 border border-stone-200 dark:border-white/10 rounded-xl hover:scale-110 transition-all cursor-pointer'><svg class='w-5 h-5 dark:hidden text-stone-600' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z'></path></svg><svg class='w-5 h-5 hidden dark:block text-yellow-400' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z'></path></svg></button><div class='mb-12'><div class='inline-flex items-center gap-3 p-4 bg-white rounded-2xl shadow-[0_25px_60px_-15px_rgba(0,0,0,0.3)] dark:shadow-[0_40px_100px_-20px_rgba(0,0,0,1)] border border-stone-100 dark:border-transparent scale-105 transition-all'><img src='{{global.logo}}' alt='{{global.company_name}}' class='w-9 h-9 object-contain' /><div class='flex flex-col text-left'><span class='text-sm font-black text-stone-900 leading-none uppercase tracking-tighter'>{{global.company_name}}</span><span class='text-[10px] text-stone-500 font-medium tracking-tight uppercase mt-1'>Customer Portal</span></div></div></div><div class='flex flex-col gap-2 mb-8'><h1 class='text-3xl font-black tracking-tight text-stone-950 dark:text-white'>Sign In</h1><p class='text-stone-500 font-medium'>Access your dashboard and subscription.</p></div><div class='flex flex-col gap-5'><div class='flex flex-col gap-2'><label class='text-xs font-black uppercase tracking-widest text-stone-400 ml-1'>Email Address</label><input id='email' type='email' placeholder='name@company.com' class='w-full p-4 bg-stone-50 dark:bg-black/20 border border-stone-200 dark:border-white/5 rounded-2xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500/50 transition-all placeholder:text-stone-400 dark:text-white' /></div><div class='flex flex-col gap-2'><label class='text-xs font-black uppercase tracking-widest text-stone-400 ml-1'>Password</label><input id='password' type='password' placeholder='••••••••' class='w-full p-4 bg-stone-50 dark:bg-black/20 border border-stone-200 dark:border-white/5 rounded-2xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500/50 transition-all placeholder:text-stone-400 dark:text-white' /></div><button onclick=\"Peera.auth.login('email', 'password')\" class='w-full py-4.5 bg-brand-500 hover:bg-brand-600 text-white rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-brand-500/20 active:scale-[0.98] transition-all cursor-pointer mt-4'>Enter Portal</button></div><div class='mt-10 pt-8 border-t border-stone-100 dark:border-white/5 text-center'><p class='text-xs text-stone-400 font-medium italic uppercase tracking-widest'>Secure Authentication Protocol Active</p></div></div></div><div class='hidden lg:flex flex-1 items-center justify-center bg-stone-50 dark:bg-black relative overflow-hidden transition-all duration-500'><div class='absolute inset-0 opacity-40' style=\"background-image: radial-gradient(#3b82f6 0.5px, transparent 0.5px); background-size: 24px 24px;\"></div><div class='absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-500/10 blur-[120px] rounded-full'></div><div class='relative z-10 text-center max-w-lg p-12'><div class='w-20 h-20 bg-white dark:bg-white/5 rounded-3xl shadow-2xl flex items-center justify-center mx-auto mb-10 border border-white/10'><svg class='w-10 h-10 text-brand-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'></path></svg></div><h2 class='text-4xl font-black text-stone-950 dark:text-white mb-4 tracking-tighter leading-tight'>Seamless Network Management</h2><p class='text-stone-500 text-lg font-medium leading-relaxed'>The ultimate billing and network orchestration system for modern ISPs.</p></div></div></div>" },
      "admin/login": { "title": "Admin Sign In", "html": "<div class='flex min-h-screen bg-stone-50 dark:bg-[#050505] font-sans overflow-hidden transition-colors duration-500 text-stone-900 dark:text-white relative'><div class='absolute inset-0 dark:hidden' style='background: radial-gradient(circle, transparent 20%, rgba(0,0,0,0.05) 100%); pointer-events: none;'></div><div class='w-full lg:w-[45%] flex flex-col justify-center items-center p-12 lg:p-20 z-20 bg-white dark:bg-[#050505] border-r border-stone-200 dark:border-white/5 shadow-2xl transition-all duration-500'><div class='w-full max-w-sm relative'><button onclick='Peera.theme.toggle()' class='absolute -top-12 right-0 p-2 bg-stone-100 dark:bg-white/5 border border-stone-200 dark:border-white/10 rounded-xl hover:scale-110 transition-all cursor-pointer'><svg class='w-5 h-5 dark:hidden text-stone-600' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z'></path></svg><svg class='w-5 h-5 hidden dark:block text-yellow-400' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z'></path></svg></button><div class='mb-12'><div class='inline-flex items-center gap-3 p-4 bg-stone-900 rounded-2xl shadow-[0_25px_60px_-15px_rgba(0,0,0,0.5)] border border-white/10 scale-105 transition-all'><div class='w-9 h-9 bg-brand-500 rounded-xl flex items-center justify-center text-white font-black text-xl'>A</div><div class='flex flex-col text-left'><span class='text-sm font-black text-white leading-none tracking-tight uppercase'>{{global.company_name}}</span><span class='text-[10px] text-stone-500 font-bold tracking-widest uppercase mt-1'>Internal Access</span></div></div></div><div class='flex flex-col gap-2 mb-8'><h1 class='text-3xl font-black tracking-tight text-white'>Control Access</h1><p class='text-stone-500 font-medium'>Administrator authentication required.</p></div><div class='flex flex-col gap-5'><div class='flex flex-col gap-2'><label class='text-xs font-black uppercase tracking-widest text-stone-400 ml-1'>Admin Email</label><input id='email' type='email' placeholder='admin@{{global.tenant_code}}.id' class='w-full p-4 bg-black/20 border border-white/5 rounded-2xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500/50 transition-all placeholder:text-stone-400 text-white' /></div><div class='flex flex-col gap-2'><label class='text-xs font-black uppercase tracking-widest text-stone-400 ml-1'>Secure Key</label><input id='password' type='password' placeholder='••••••••' class='w-full p-4 bg-black/20 border border-white/5 rounded-2xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500/50 transition-all placeholder:text-stone-400 text-white' /></div><button onclick=\"Peera.auth.login('email', 'password')\" class='w-full py-4.5 bg-white text-black rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-white/5 active:scale-[0.98] transition-all cursor-pointer mt-4'>Verify Credentials</button></div><div class='mt-10 pt-8 border-t border-white/5 text-center'><p class='text-xs text-stone-500 font-medium'>Protected by Peera Core Security</p></div></div></div><div class='hidden lg:flex flex-1 items-center justify-center bg-black relative overflow-hidden'><div class='absolute inset-0 opacity-20' style=\"background-image: radial-gradient(#fff 0.5px, transparent 0.5px); background-size: 32px 32px;\"></div><div class='absolute bottom-0 left-0 w-full h-full bg-gradient-to-t from-brand-500/20 to-transparent'></div><div class='relative z-10 text-center max-w-lg p-12'><div class='mb-10 inline-flex items-center gap-2 px-4 py-2 bg-red-500/10 border border-red-500/20 rounded-full'><div class='w-2 h-2 bg-red-500 rounded-full animate-pulse'></div><span class='text-[10px] font-black text-red-500 uppercase tracking-widest'>Admin Terminal</span></div><h2 class='text-5xl font-black text-white mb-6 tracking-tighter leading-[0.9] uppercase italic'>System<br/>Orchestrator</h2><p class='text-stone-500 text-lg font-medium leading-relaxed'>Manage global infrastructure, tenants, and system-wide design schemas.</p></div></div></div>" },
      "admin/dashboard": { "title": "Admin Dashboard", "html": "<div class='p-8 lg:p-12 max-w-7xl mx-auto flex flex-col gap-12'><div class='flex flex-col gap-3'><h1 class='text-4xl font-black text-stone-900 dark:text-white tracking-tighter uppercase tracking-[0.1em]'>Control Center</h1><p class='text-stone-500 font-black text-xs tracking-[0.3em] uppercase'>Infrastructure Management & Automation</p></div><div class='grid grid-cols-1 md:grid-cols-4 gap-8'><div class='p-10 bg-stone-900 border border-stone-800 rounded-[40px] shadow-2xl relative overflow-hidden group hover:scale-[1.02] transition-all'><div class='absolute top-0 right-0 w-32 h-32 bg-brand-500/10 blur-3xl rounded-full'></div><p class='text-stone-500 text-[10px] font-black uppercase tracking-[0.3em] mb-4'>Total Tenants</p><h3 class='text-5xl font-black text-white tracking-tighter'>1,284</h3></div><div class='p-10 bg-stone-900 border border-stone-800 rounded-[40px] shadow-2xl relative overflow-hidden group hover:scale-[1.02] transition-all'><p class='text-stone-500 text-[10px] font-black uppercase tracking-[0.3em] mb-4'>Active Nodes</p><h3 class='text-5xl font-black text-green-400 font-mono tracking-tighter'>99.9%</h3></div></div></div>" },
      "admin/theme": {
        "title": "Admin Theme Designer",
