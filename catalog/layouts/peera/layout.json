    "contents": {
      "login": { "title": "Portal Login", "html": "<div class='flex min-h-screen bg-stone-50 dark:bg-[#050505] font-sans overflow-hidden transition-colors duration-500 text-stone-900 dark:text-white relative'><div class='absolute inset-0 dark:hidden' style='background: radial-gradient(circle, transparent 20%, rgba(0,0,0,0.05) 100%); pointer-events: none;'></div><div class='w-full lg:w-[45%] flex flex-col justify-center items-center p-12 lg:p-20 z-20 bg-white dark:bg-[#050505] border-r border-stone-200 dark:border-white/5 shadow-2xl transition-all duration-500'><div class='w-full max-sm:px-4 max-w-sm relative'><button onclick='Peera.theme.toggle()' class='absolute -top-12 right-0 p-2 bg-stone-100 dark:bg-white/5 border border-stone-200 dark:border-white/10 rounded-xl hover:scale-110 transition-all cursor-pointer'><svg class='w-5 h-5 dark:hidden text-stone-600' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z'></path></svg><svg class='w-5 h-5 hidden dark:block text-yellow-400' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z'></path></svg></button><div class='mb-12'><div class='inline-flex items-center gap-3 p-4 bg-white rounded-2xl shadow-[0_25px_60px_-15px_rgba(0,0,0,0.3)] dark:shadow-[0_40px_100px_-20px_rgba(0,0,0,1)] border border-stone-100 dark:border-transparent scale-105 transition-all'><img src='{{global.logo}}' alt='{{global.company_name}}' class='w-9 h-9 object-contain' /><div class='flex flex-col text-left'><span class='text-sm font-black text-stone-900 leading-none uppercase tracking-tighter'>{{global.company_name}}</span><span class='text-[10px] text-stone-500 font-medium tracking-tight uppercase mt-1'>Customer Portal</span></div></div></div><div class='flex flex-col gap-2 mb-8'><h1 class='text-3xl font-black tracking-tight text-stone-950 dark:text-white'>Sign In</h1><p class='text-stone-500 font-medium'>Access your dashboard and subscription.</p></div><div class='flex flex-col gap-5'><div class='flex flex-col gap-2'><label class='text-xs font-black uppercase tracking-widest text-stone-400 ml-1'>Email Address</label><input id='email' type='email' placeholder='name@company.com' class='w-full p-4 bg-stone-50 dark:bg-black/20 border border-stone-200 dark:border-white/5 rounded-2xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500/50 transition-all placeholder:text-stone-400 dark:text-white' /></div><div class='flex flex-col gap-2'><label class='text-xs font-black uppercase tracking-widest text-stone-400 ml-1'>Password</label><input id='password' type='password' placeholder='••••••••' class='w-full p-4 bg-stone-50 dark:bg-black/20 border border-stone-200 dark:border-white/5 rounded-2xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500/50 transition-all placeholder:text-stone-400 dark:text-white' /></div><button onclick=\"Peera.auth.login('email', 'password')\" class='w-full py-4.5 bg-brand-500 hover:bg-brand-600 text-white rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-brand-500/20 active:scale-[0.98] transition-all cursor-pointer mt-4'>Enter Portal</button></div><div class='mt-10 pt-8 border-t border-stone-100 dark:border-white/5 text-center'><p class='text-xs text-stone-400 font-medium italic uppercase tracking-widest'>Secure Authentication Protocol Active</p></div></div></div><div class='hidden lg:flex flex-1 items-center justify-center bg-stone-50 dark:bg-black relative overflow-hidden transition-all duration-500'><div class='absolute inset-0 opacity-40' style=\"background-image: radial-gradient(#3b82f6 0.5px, transparent 0.5px); background-size: 24px 24px;\"></div><div class='absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-500/10 blur-[120px] rounded-full'></div><div class='relative z-10 text-center max-w-lg p-12'><div class='w-20 h-20 bg-white dark:bg-white/5 rounded-3xl shadow-2xl flex items-center justify-center mx-auto mb-10 border border-white/10'><svg class='w-10 h-10 text-brand-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'></path></svg></div><h2 class='text-4xl font-black text-stone-950 dark:text-white mb-4 tracking-tighter leading-tight'>Seamless Network Management</h2><p class='text-stone-500 text-lg font-medium leading-relaxed'>The ultimate billing and network orchestration system for modern ISPs.</p></div></div></div>" },
      "admin/login": { "title": "Admin Login", "html": "<div class='flex min-h-screen bg-stone-50 dark:bg-[#050505] font-sans overflow-hidden transition-colors duration-500 text-stone-900 dark:text-white relative'><div class='absolute inset-0 dark:hidden' style='background: radial-gradient(circle, transparent 20%, rgba(0,0,0,0.05) 100%); pointer-events: none;'></div><div class='w-full lg:w-[45%] flex flex-col justify-center items-center p-12 lg:p-20 z-20 bg-white dark:bg-[#050505] border-r border-stone-200 dark:border-white/5 shadow-2xl transition-all duration-500'><div class='w-full max-w-sm relative'><button onclick='Peera.theme.toggle()' class='absolute -top-12 right-0 p-2 bg-stone-100 dark:bg-white/5 border border-stone-200 dark:border-white/10 rounded-xl hover:scale-110 transition-all cursor-pointer'><svg class='w-5 h-5 dark:hidden text-stone-600' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z'></path></svg><svg class='w-5 h-5 hidden dark:block text-yellow-400' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z'></path></svg></button><div class='mb-12'><div class='inline-flex items-center gap-3 p-4 bg-stone-900 rounded-2xl shadow-[0_25px_60px_-15px_rgba(0,0,0,0.5)] border border-white/10 scale-105 transition-all'><div class='w-9 h-9 bg-brand-500 rounded-xl flex items-center justify-center text-white font-black text-xl'>A</div><div class='flex flex-col text-left'><span class='text-sm font-black text-white leading-none tracking-tight uppercase'>{{global.company_name}}</span><span class='text-[10px] text-stone-500 font-bold tracking-widest uppercase mt-1'>Internal Access</span></div></div></div><div class='flex flex-col gap-2 mb-8'><h1 class='text-3xl font-black tracking-tight text-white'>Control Access</h1><p class='text-stone-500 font-medium'>Administrator authentication required.</p></div><div class='flex flex-col gap-5'><div class='flex flex-col gap-2'><label class='text-xs font-black uppercase tracking-widest text-stone-400 ml-1'>Admin Email</label><input id='admin-email' type='email' placeholder='admin@{{global.tenant_code}}.id' class='w-full p-4 bg-black/20 border border-white/5 rounded-2xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500/50 transition-all placeholder:text-stone-400 text-white' /></div><div class='flex flex-col gap-2'><label class='text-xs font-black uppercase tracking-widest text-stone-400 ml-1'>Secure Key</label><input id='admin-password' type='password' placeholder='••••••••' class='w-full p-4 bg-black/20 border border-white/5 rounded-2xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500/50 transition-all placeholder:text-stone-400 text-white' /></div><button onclick=\"Peera.auth.login('admin-email', 'admin-password')\" class='w-full py-4.5 bg-white text-black rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-white/5 active:scale-[0.98] transition-all cursor-pointer mt-4'>Verify Credentials</button></div><div class='mt-10 pt-8 border-t border-white/5 text-center'><p class='text-xs text-stone-500 font-medium'>Protected by Peera Core Security</p></div></div></div><div class='hidden lg:flex flex-1 items-center justify-center bg-black relative overflow-hidden'><div class='absolute inset-0 opacity-20' style=\"background-image: radial-gradient(#fff 0.5px, transparent 0.5px); background-size: 32px 32px;\"></div><div class='absolute bottom-0 left-0 w-full h-full bg-gradient-to-t from-brand-500/20 to-transparent'></div><div class='relative z-10 text-center max-w-lg p-12'><div class='mb-10 inline-flex items-center gap-2 px-4 py-2 bg-red-500/10 border border-red-500/20 rounded-full'><div class='w-2 h-2 bg-red-500 rounded-full animate-pulse'></div><span class='text-[10px] font-black text-red-500 uppercase tracking-widest'>Admin Terminal</span></div><h2 class='text-5xl font-black text-white mb-6 tracking-tighter leading-[0.9] uppercase italic'>System<br/>Orchestrator</h2><p class='text-stone-500 text-lg font-medium leading-relaxed'>Manage global infrastructure, tenants, and system-wide design schemas.</p></div></div></div>" },
      "dashboard": { "title": "Dashboard", "html": "<div class='flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Platform Dashboard</h2><div class='overflow-hidden rounded-3xl border border-slate-200 bg-[linear-gradient(135deg,_#0f172a_0%,_#111827_42%,_#1e293b_100%)] p-6 text-white shadow-lg'><div class='flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between'><div class='max-w-2xl'><span class='inline-flex rounded-full border border-white/15 bg-white/10 px-3 py-1 text-[10px] font-medium uppercase tracking-[0.24em] text-sky-100'>Sovereign Portal</span><h2 class='mt-3 text-2xl font-bold tracking-tight'>Greetings, {{global.customer_fullname}}</h2><p class='mt-2 text-sm leading-relaxed text-slate-300'>Access your secure ISP orchestration panel and monitoring artifacts.</p></div><div class='min-w-[220px] rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur-sm'><p class='text-[10px] font-bold uppercase tracking-[0.22em] text-slate-300'>Access Status</p><p class='mt-1.5 text-lg font-bold text-white'>{{global.customer_status}}</p></div></div></div><div class='grid grid-cols-1 gap-6 md:grid-cols-3'><div class='p-6 rounded-3xl border border-slate-200 bg-white dark:bg-gray-800 dark:border-gray-700 shadow-sm'><p class='text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500'>Plan</p><p class='mt-4 text-2xl font-bold tracking-tight text-slate-950 dark:text-white'>{{status.service_plan}}</p></div><div class='p-6 rounded-3xl border border-slate-200 bg-white dark:bg-gray-800 dark:border-gray-700 shadow-sm'><p class='text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500'>Obligation</p><p class='mt-4 text-2xl font-bold tracking-tight text-slate-950 dark:text-white tabular-nums'>{{global.currency}} {{billing.total_amount}}</p></div><div class='p-6 rounded-3xl border border-slate-200 bg-white dark:bg-gray-800 dark:border-gray-700 shadow-sm'><p class='text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500'>Link</p><p class='mt-4 text-2xl font-bold tracking-tight text-emerald-600'>{{status.status}}</p></div></div></div>" },
      "status": { "title": "Status", "html": "<div class='flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Network Status</h2><div class='bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-3xl p-8 grid grid-cols-2 gap-12 shadow-sm'><div class='flex flex-col gap-1'><span class='text-xs text-gray-500 font-bold uppercase'>Connection Status</span><span class='text-3xl font-bold text-emerald-600'>{{status.status}}</span></div><div class='flex flex-col gap-1'><span class='text-xs text-gray-500 font-bold uppercase'>Assigned IP</span><span class='text-2xl font-mono font-bold dark:text-white'>{{status.active_ip}}</span></div><div class='flex flex-col gap-1'><span class='text-xs text-gray-500 font-bold uppercase'>Readiness</span><span class='text-xl font-bold text-brand-600 uppercase'>{{status.is_online}}</span></div><div class='flex flex-col gap-1'><span class='text-xs text-gray-500 font-bold uppercase'>Service Plan</span><span class='text-xl font-bold dark:text-white uppercase'>{{status.service_plan}}</span></div></div></div>" },
      "billing": { "title": "Billing", "html": "<div class='flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Billing Ledger</h2><div class='grid grid-cols-12 gap-6'><div class='col-span-8 p-10 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-3xl shadow-sm flex flex-col gap-8'><div class='flex flex-col gap-1'><span class='text-xs text-gray-500 font-bold uppercase'>Total Outstanding</span><span class='text-6xl font-bold text-gray-900 dark:text-white tabular-nums tracking-tighter'>{{global.currency}} {{billing.total_amount}}</span></div><div class='grid grid-cols-3 gap-6 border-t border-gray-100 dark:border-gray-700 pt-6'><div class='flex flex-col'><span class='text-[10px] text-gray-400 font-bold uppercase'>Net</span><span class='text-sm font-bold dark:text-white'>{{global.currency}} {{billing.subtotal}}</span></div><div class='flex flex-col'><span class='text-[10px] text-gray-400 font-bold uppercase'>Tax</span><span class='text-sm font-bold dark:text-white'>{{global.currency}} {{billing.tax_amount}}</span></div><div class='flex flex-col'><span class='text-[10px] text-gray-400 font-bold uppercase'>Paid</span><span class='text-sm font-bold text-emerald-600'>{{global.currency}} {{billing.total_paid}}</span></div></div><a href='{{functional.action_pay_invoice}}' target='_blank' class='w-full py-4 bg-brand-500 hover:bg-brand-600 text-white rounded-xl text-center font-bold text-sm shadow-lg shadow-brand-500/20 transition-all'>Pay Now</a></div><div class='col-span-4 p-8 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-3xl flex flex-col gap-6'><span class='text-[10px] font-bold text-gray-500 uppercase'>Invoice Artifact</span><div class='flex flex-col gap-4'><div class='flex justify-between'><span class='text-xs text-gray-400 uppercase'>#ID</span><span class='text-sm font-bold dark:text-white'>{{billing.invoice_number}}</span></div><div class='flex justify-between'><span class='text-xs text-gray-400 uppercase'>Due</span><span class='text-sm font-bold text-red-600'>{{billing.due_date}}</span></div><div class='pt-4 border-t border-gray-200 dark:border-white/10 flex flex-col'><span class='text-[9px] text-gray-400 uppercase'>Service Window</span><p class='text-[10px] font-bold dark:text-white'>{{billing.period_start}} - {{billing.period_end}}</p></div></div></div></div></div>" },
      "support": { "title": "Support", "html": "<div class='flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Support Center</h2><div class='bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-3xl p-10 flex flex-col gap-8 shadow-sm'><div class='flex justify-between items-center'><div class='flex items-center gap-4'><span class='px-2.5 py-1 bg-brand-500 text-white rounded text-[10px] font-bold'>#{{support.ticket_number}}</span><h4 class='text-xl font-bold text-gray-900 dark:text-white uppercase'>{{support.title}}</h4></div><div class='text-indigo-600 text-[10px] font-bold uppercase tracking-widest'>{{support.status}}</div></div><p class='text-gray-500 text-base italic leading-relaxed'>\"{{support.description}}\"</p><div class='grid grid-cols-3 gap-10 pt-10 border-t border-gray-100 dark:border-gray-800'><div class='flex flex-col gap-1'><span class='text-[10px] text-gray-400 font-bold uppercase'>Priority</span><span class='text-sm font-bold text-amber-600 uppercase'>{{support.priority}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] text-gray-400 font-bold uppercase'>Created</span><span class='text-sm font-bold dark:text-white'>{{support.created_at}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] text-gray-400 font-bold uppercase'>Scheduled</span><span class='text-sm font-bold dark:text-white uppercase'>{{support.scheduled_at}}</span></div></div></div></div>" },
      "documents": { "title": "Documents", "html": "<div class='flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Digital Archive</h2><div class='grid grid-cols-1 md:grid-cols-2 gap-6'><div class='p-8 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm flex items-center justify-between group hover:border-brand-500/30 transition-all'><div class='flex items-center gap-6'><div class='w-14 h-14 bg-gray-50 dark:bg-gray-900 rounded-xl flex items-center justify-center text-gray-400 group-hover:text-brand-600 transition-colors'><svg width='28' height='28' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z'/><polyline points='14 2 14 8 20 8'/></svg></div><div class='flex flex-col gap-0.5'><span class='text-lg font-bold text-gray-900 dark:text-white uppercase tracking-tight'>{{documents.name}}</span><span class='text-[10px] text-gray-500 font-medium italic'>System Artifact &bull; PDF</span></div></div><a href='{{documents.file_url}}' target='_blank' class='px-6 py-2.5 bg-brand-500 hover:bg-brand-600 text-white rounded-xl text-xs font-bold shadow-lg transition-all'>Download</a></div></div></div>" },
      "profile": { "title": "Profile", "html": "<div class='flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Profile Settings</h2><div class='bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-3xl p-12 flex flex-col gap-12 shadow-sm'><div class='grid grid-cols-2 gap-20'><div class='flex flex-col gap-10'><div class='flex flex-col gap-1'><span class='text-[10px] text-gray-400 font-bold uppercase tracking-widest'>Legal Name</span><span class='text-3xl font-bold text-gray-900 dark:text-white'>{{profile.fullname}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] text-gray-400 font-bold uppercase tracking-widest'>Access ID</span><span class='text-2xl font-mono text-brand-600 font-bold'>{{profile.cust_id}}</span></div></div><div class='flex flex-col gap-10'><div class='flex flex-col gap-1'><span class='text-[10px] text-gray-400 font-bold uppercase tracking-widest'>Email Grid</span><span class='text-xl font-bold dark:text-white'>{{profile.email}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] text-gray-400 font-bold uppercase tracking-widest'>Auth Status</span><span class='text-xl font-bold text-emerald-600 uppercase tracking-widest italic'>{{profile.status}}</span></div></div></div><div class='pt-10 border-t border-gray-100 dark:border-gray-800 flex flex-col gap-2'><span class='text-[10px] text-gray-400 font-bold uppercase tracking-widest'>Installation Address</span><p class='text-xl font-medium text-gray-600 dark:text-gray-400 italic'>\"{{profile.address}}\"</p></div></div></div>" },
      "admin/theme": {
        "title": "Admin Theme Designer",
        "html": "<div class='min-h-screen bg-white dark:bg-[#050505] font-sans flex flex-col items-center justify-center p-8 lg:p-20 relative overflow-hidden transition-colors duration-500'><div class='absolute inset-0 premium-grid opacity-[0.4] dark:opacity-[0.1]'></div><div class='absolute top-0 left-0 w-[600px] h-[600px] bg-brand-500/10 blur-[150px] rounded-full -translate-x-1/2 -translate-y-1/2 opacity-0 dark:opacity-50 transition-opacity duration-1000'></div><div class='absolute bottom-0 right-0 w-[600px] h-[600px] bg-blue-600/5 blur-[150px] rounded-full translate-x-1/2 translate-y-1/2 opacity-0 dark:opacity-30 transition-opacity duration-1000'></div><div class='w-full max-w-5xl relative z-10'><div class='flex flex-col gap-4 mb-16 text-center'><h1 class='text-7xl font-black text-stone-950 dark:text-white uppercase tracking-[0.2em] italic transition-all hover:tracking-[0.25em] duration-1000'>Theme Studio</h1><div class='h-1.5 w-48 bg-gradient-to-r from-transparent via-brand-500 to-transparent mx-auto rounded-full mt-2 shadow-[0_10px_30px_-5px_rgba(59,130,246,0.5)]'></div><p class='text-stone-500 font-black uppercase tracking-[0.6em] text-[9px] mt-8 opacity-70'>Architecting the Future of Network UI</p></div><div class='grid grid-cols-1 md:grid-cols-2 gap-12'><div class='group p-14 bg-white/40 dark:bg-white/5 backdrop-blur-2xl border border-stone-200 dark:border-white/10 rounded-[60px] hover:border-brand-500/40 transition-all duration-700 shadow-2xl shadow-black/5 dark:shadow-3xl relative overflow-hidden'><div class='absolute -top-10 -right-10 w-40 h-40 bg-brand-500/5 blur-3xl rounded-full group-hover:scale-150 transition-transform duration-1000'></div><div class='flex flex-col gap-10 relative z-10'><div class='w-20 h-20 bg-stone-100 dark:bg-brand-500/20 rounded-[28px] flex items-center justify-center text-stone-950 dark:text-brand-500 group-hover:rotate-6 transition-all duration-500 shadow-xl shadow-black/5'><svg class='w-10 h-10' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4'></path></svg></div><div class='flex flex-col gap-4'><h2 class='text-2xl font-black text-stone-950 dark:text-white uppercase tracking-widest'>Live Engine</h2><p class='text-sm text-stone-500 leading-relaxed font-medium'>Experience real-time UI orchestration. Inject dynamic schemas and validate your vision instantly.</p></div><button onclick='Peera.dev.toggle()' class='w-full py-6 bg-stone-950 dark:bg-white text-white dark:text-black rounded-[30px] text-[11px] font-black uppercase tracking-[0.3em] transition-all active:scale-95 shadow-2xl shadow-black/20 dark:shadow-white/10 hover:shadow-brand-500/20'>Initiate Engine</button></div></div><div class='group p-14 bg-white/40 dark:bg-white/5 backdrop-blur-2xl border border-stone-200 dark:border-white/10 rounded-[60px] hover:border-blue-500/40 transition-all duration-700 shadow-2xl shadow-black/5 dark:shadow-3xl relative overflow-hidden'><div class='absolute -bottom-10 -left-10 w-40 h-40 bg-blue-600/5 blur-3xl rounded-full group-hover:scale-150 transition-transform duration-1000'></div><div class='flex flex-col gap-10 relative z-10'><div class='w-20 h-20 bg-stone-100 dark:bg-blue-600/20 rounded-[28px] flex items-center justify-center text-stone-950 dark:text-blue-400 group-hover:-rotate-6 transition-all duration-500 shadow-xl shadow-black/5'><svg class='w-10 h-10' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'></path><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'></path></svg></div><div class='flex flex-col gap-4'><h2 class='text-2xl font-black text-stone-950 dark:text-white uppercase tracking-widest'>Portal Preview</h2><p class='text-sm text-stone-500 leading-relaxed font-medium'>Step into your customer's world. Preview the complete journey with the latest architectural layout.</p></div><button onclick='Peera.dev.launch()' class='w-full py-6 bg-blue-600 text-white rounded-[30px] text-[11px] font-black uppercase tracking-[0.3em] transition-all active:scale-95 shadow-2xl shadow-blue-600/30 hover:shadow-blue-600/50'>Launch Portal</button></div></div></div><div class='mt-24 pt-10 border-t border-stone-200 dark:border-white/10 flex justify-between items-center'><div class='flex items-center gap-4'><div class='w-2.5 h-2.5 bg-green-500 rounded-full animate-ping absolute'></div><div class='w-2.5 h-2.5 bg-green-500 rounded-full relative'></div><span class='text-[10px] font-black uppercase tracking-[0.3em] text-stone-950 dark:text-white opacity-40'>System Status: Verified</span></div><div class='flex gap-8'><span class='text-[9px] font-black uppercase tracking-[0.3em] text-stone-400 hover:text-stone-950 dark:hover:text-white cursor-pointer transition-colors'>Documentation</span><span onclick='Peera.dev.toggle()' class='text-[9px] font-black uppercase tracking-[0.3em] text-red-500/50 hover:text-red-500 cursor-pointer transition-colors'>Emergency Kill-Switch</span></div></div></div></div>" }
    }
  },
