{
  "version": "1.0.0",
  "name": "Peera Default",
  "description": "Standard layout for all new tenants",
  "layout": {
    "nav": { "items": [ { "id": "nav.home", "label": "Home", "url": "/" }, { "id": "nav.status", "label": "Status", "url": "/status" }, { "id": "nav.billing", "label": "Billing", "url": "/billing" }, { "id": "nav.docs", "label": "Documents", "url": "/documents" }, { "id": "nav.profile", "label": "Profile", "url": "/profile" }, { "id": "nav.signout", "label": "Sign Out", "html": "<button onclick='Peera.auth.logout()' class='w-full mt-4 bg-red-900/20 hover:bg-red-900/40 text-red-400 p-2 rounded-lg transition-colors text-sm font-medium cursor-pointer'>Sign Out</button>" } ] },
    "signout": { "script": "auth.logout" },
    "contents": {
      "dashboard": { "title": "Dashboard", "html": "<div class='p-8 lg:p-12 max-w-7xl mx-auto flex flex-col gap-10'><div class='flex justify-between items-end'><div class='flex flex-col gap-2'><h1 class='text-3xl font-black text-stone-900 dark:text-white tracking-tight'>Welcome, {{tenant_name_final}}</h1><p class='text-stone-500 font-medium'>Manage your subscription and connection details.</p></div><div class='bg-green-500/10 text-green-500 px-4 py-2 rounded-xl font-bold text-xs uppercase tracking-widest border border-green-500/20 transition-all'>Status: Active</div></div><div class='grid grid-cols-1 md:grid-cols-3 gap-8'><div class='p-8 bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-[32px] shadow-xl'><p class='text-stone-500 text-[10px] font-black uppercase tracking-[0.2em] mb-2'>Outstanding Balance</p><h3 class='text-4xl font-black text-stone-950 dark:text-white'>{{currency}} 0.00</h3></div><div class='p-8 bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-[32px] shadow-xl'><p class='text-stone-500 text-[10px] font-black uppercase tracking-[0.2em] mb-2'>Connection Speed</p><h3 class='text-4xl font-black text-blue-500'>50 <span class='text-lg'>Mbps</span></h3></div><div class='p-8 bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-[32px] shadow-xl'><p class='text-stone-500 text-[10px] font-black uppercase tracking-[0.2em] mb-2'>Billing Cycle</p><h3 class='text-4xl font-black text-stone-950 dark:text-white italic'>Monthly</h3></div></div></div>" },
      "billing": { "title": "Billing", "html": "<div class='p-12 max-w-7xl mx-auto'><h1 class='text-3xl font-black text-stone-900 dark:text-white mb-8'>Billing History</h1><div class='p-20 border border-dashed border-stone-300 dark:border-stone-800 rounded-[40px] text-center text-stone-500 italic'>No invoices found for this account.</div></div>" },
      "status": { "title": "Status", "html": "<div class='p-12 max-w-7xl mx-auto'><h1 class='text-3xl font-black text-stone-900 dark:text-white mb-8'>Network Status</h1><div class='grid grid-cols-1 md:grid-cols-2 gap-8'><div class='p-8 bg-green-500/5 border border-green-500/20 rounded-[32px]'><h3 class='font-bold text-green-500'>Main Infrastructure</h3><p class='text-sm text-stone-500 mt-1 uppercase font-black tracking-widest'>Operational</p></div><div class='p-8 bg-blue-500/5 border border-blue-500/20 rounded-[32px]'><h3 class='font-bold text-blue-500'>Global Gateway</h3><p class='text-sm text-stone-500 mt-1 uppercase font-black tracking-widest'>Healthy</p></div></div></div>" },
      "login": { "title": "Sign In", "html": "<div class='flex min-h-screen bg-stone-50 dark:bg-[#050505] font-sans overflow-hidden transition-colors duration-500 text-stone-900 dark:text-white relative'><div class='absolute inset-0 dark:hidden' style='background: radial-gradient(circle, transparent 20%, rgba(0,0,0,0.05) 100%); pointer-events: none;'></div><div class='w-full lg:w-[45%] flex flex-col justify-center items-center p-12 lg:p-20 z-20 bg-white dark:bg-[#050505] border-r border-stone-200 dark:border-white/5 shadow-2xl transition-all duration-500'><div class='w-full max-w-sm relative'><button onclick='Peera.theme.toggle()' class='absolute -top-12 right-0 p-2 bg-stone-100 dark:bg-white/5 border border-stone-200 dark:border-white/10 rounded-xl hover:scale-110 transition-all cursor-pointer'><svg class='w-5 h-5 dark:hidden text-stone-600' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z'></path></svg><svg class='w-5 h-5 hidden dark:block text-yellow-400' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z'></path></svg></button><div class='mb-12'><div class='inline-flex items-center gap-3 p-4 bg-white rounded-2xl shadow-[0_25px_60px_-15px_rgba(0,0,0,0.3)] dark:shadow-[0_40px_100px_-20px_rgba(0,0,0,1)] border border-stone-100 dark:border-transparent scale-105 transition-all'><img src='{{logo}}' alt='{{company_name}}' class='w-9 h-9 object-contain' /><div class='flex flex-col text-left'><span class='text-sm font-black text-stone-900 leading-none'>{{company_name}}</span><span class='text-[10px] text-stone-500 font-medium tracking-tight uppercase mt-1'>Customer Portal</span></div></div></div><div class='flex flex-col gap-2 mb-10 text-left w-full'><h1 class='text-4xl font-black text-stone-900 dark:text-white tracking-tighter transition-colors'>Sign In</h1><p class='text-stone-500 dark:text-stone-400 text-sm font-medium'>Access your billing account for {{company_name}}.</p></div><div class='flex flex-col gap-6 w-full'><div class='flex flex-col gap-2'><label class='text-[10px] font-bold text-stone-400 dark:text-stone-500 uppercase tracking-[0.2em]'>Email Address</label><input type='email' id='email' placeholder='name@company.com' class='w-full p-4 bg-stone-50 dark:bg-white/5 border border-stone-200 dark:border-white/10 rounded-2xl text-stone-900 dark:text-white placeholder-stone-400 dark:placeholder-stone-700 outline-none focus:ring-2 focus:ring-brand-500/50 focus:bg-white dark:focus:bg-white/10 transition-all font-medium' /></div><div class='flex flex-col gap-2'><label class='text-[10px] font-bold text-stone-400 dark:text-stone-500 uppercase tracking-[0.2em]'>Password</label><input type='password' id='password' placeholder='••••••••' class='w-full p-4 bg-stone-50 dark:bg-white/5 border border-stone-200 dark:border-white/10 rounded-2xl text-stone-900 dark:text-white placeholder-stone-400 dark:placeholder-stone-700 outline-none focus:ring-2 focus:ring-brand-500/50 focus:bg-white dark:focus:bg-white/10 transition-all font-medium' /></div><button onclick='Peera.auth.login(`email`, `password`)' class='w-full py-4.5 bg-brand-500 hover:bg-brand-600 text-white font-bold rounded-2xl shadow-2xl shadow-brand-500/40 active:scale-[0.98] transition-all cursor-pointer mt-4 text-sm tracking-wide'>Sign In to Portal</button></div><div class='mt-16 text-[10px] text-stone-400 dark:text-stone-600 font-medium uppercase tracking-widest text-left w-full'>Powered by {{company_name}} · © 2026</div></div></div><div class='hidden lg:flex flex-1 relative items-center justify-center bg-stone-50 dark:bg-black overflow-hidden transition-colors duration-500'><div class='absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-brand-500/10 dark:bg-brand-500/15 blur-[120px] rounded-full opacity-60'></div><div class='absolute inset-0 opacity-[0.05] dark:opacity-20 transition-opacity' style='background-image: linear-gradient(#333 1px, transparent 1px), linear-gradient(90deg, #333 1px, transparent 1px); background-size: 60px 60px;'></div><div class='relative z-20 flex flex-col items-center gap-8 text-center'><div class='w-32 h-32 bg-white dark:bg-brand-500/10 border border-stone-200 dark:border-brand-500/20 backdrop-blur-3xl rounded-[40px] flex items-center justify-center p-6 shadow-[0_40px_100px_-20px_rgba(0,0,0,0.5)] dark:shadow-[0_60px_150px_-30px_rgba(0,0,0,1)] transition-all'><img src='{{logo}}' alt='Logo' class='w-full h-full object-contain dark:brightness-0 dark:invert opacity-90' /></div><div class='flex flex-col gap-2'><h2 class='text-4xl font-black text-stone-900 dark:text-white uppercase tracking-[0.25em] leading-tight transition-colors'>{{company_name}}</h2><div class='h-1 w-20 bg-brand-500 mx-auto rounded-full'></div><p class='text-stone-500 dark:text-stone-400 max-w-sm mt-4 font-medium text-lg leading-relaxed transition-colors'>Empowering your digital experience with seamless automation.</p></div></div></div></div>" },
      "admin/login": { "title": "Admin Sign In", "html": "<div class='flex min-h-screen bg-stone-50 dark:bg-[#050505] font-sans overflow-hidden transition-colors duration-500 text-stone-900 dark:text-white relative'><div class='absolute inset-0 dark:hidden' style='background: radial-gradient(circle, transparent 20%, rgba(0,0,0,0.05) 100%); pointer-events: none;'></div><div class='w-full lg:w-[45%] flex flex-col justify-center items-center p-12 lg:p-20 z-20 bg-white dark:bg-[#050505] border-r border-stone-200 dark:border-white/5 shadow-2xl transition-all duration-500'><div class='w-full max-w-sm relative'><button onclick='Peera.theme.toggle()' class='absolute -top-12 right-0 p-2 bg-stone-100 dark:bg-white/5 border border-stone-200 dark:border-white/10 rounded-xl hover:scale-110 transition-all cursor-pointer'><svg class='w-5 h-5 dark:hidden text-stone-600' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z'></path></svg><svg class='w-5 h-5 hidden dark:block text-yellow-400' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z'></path></svg></button><div class='mb-12'><div class='inline-flex items-center gap-3 p-4 bg-stone-900 rounded-2xl shadow-[0_25px_60px_-15px_rgba(0,0,0,0.5)] border border-white/10 scale-105 transition-all'><div class='w-9 h-9 bg-brand-500 rounded-xl flex items-center justify-center text-white font-black text-xl'>A</div><div class='flex flex-col text-left'><span class='text-sm font-black text-white leading-none tracking-tight'>Peera Admin</span><span class='text-[10px] text-stone-500 font-bold tracking-widest uppercase mt-1'>Internal Access</span></div></div></div><div class='flex flex-col gap-2 mb-10 text-left w-full'><h1 class='text-4xl font-black text-stone-900 dark:text-white tracking-tighter transition-colors'>Admin Login</h1><p class='text-stone-500 dark:text-stone-400 text-sm font-medium'>Management portal for {{company_name}}.</p></div><div class='flex flex-col gap-6 w-full'><div class='flex flex-col gap-2'><label class='text-[10px] font-bold text-stone-400 dark:text-stone-500 uppercase tracking-[0.2em]'>Admin Email</label><input type='email' id='email' placeholder='admin@peera.id' class='w-full p-4 bg-stone-50 dark:bg-white/5 border border-stone-200 dark:border-white/10 rounded-2xl text-stone-900 dark:text-white placeholder-stone-400 dark:placeholder-stone-700 outline-none focus:ring-2 focus:ring-brand-500/50 focus:bg-white dark:focus:bg-white/10 transition-all font-medium' /></div><div class='flex flex-col gap-2'><label class='text-[10px] font-bold text-stone-400 dark:text-stone-500 uppercase tracking-[0.2em]'>Secure Password</label><input type='password' id='password' placeholder='••••••••' class='w-full p-4 bg-stone-50 dark:bg-white/5 border border-stone-200 dark:border-white/10 rounded-2xl text-stone-900 dark:text-white placeholder-stone-400 dark:placeholder-stone-700 outline-none focus:ring-2 focus:ring-brand-500/50 focus:bg-white dark:focus:bg-white/10 transition-all font-medium' /></div><button onclick='Peera.auth.login(`email`, `password`)' class='w-full py-4.5 bg-brand-500 hover:bg-brand-600 text-white font-bold rounded-2xl shadow-2xl shadow-brand-500/40 active:scale-[0.98] transition-all cursor-pointer mt-4 text-sm tracking-wide'>Unlock Admin Portal</button></div><div class='mt-16 text-[10px] text-stone-400 dark:text-stone-600 font-bold uppercase tracking-widest text-left w-full'>Internal Use Only · Security Protocol Active</div></div></div><div class='hidden lg:flex flex-1 relative items-center justify-center bg-stone-900 dark:bg-black overflow-hidden transition-colors duration-500'><div class='absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-brand-500/20 blur-[150px] rounded-full opacity-60'></div><div class='absolute inset-0 opacity-[0.1]' style='background-image: linear-gradient(#333 1px, transparent 1px), linear-gradient(90deg, #333 1px, transparent 1px); background-size: 60px 60px;'></div><div class='relative z-20 flex flex-col items-center gap-8 text-center'><div class='w-32 h-32 bg-brand-500 rounded-[40px] flex items-center justify-center shadow-[0_50px_100px_-20px_rgba(70,95,255,0.6)] transition-all'><span class='text-6xl font-black text-white'>A</span></div><div class='flex flex-col gap-2'><h2 class='text-4xl font-black text-white uppercase tracking-[0.25em] leading-tight transition-colors'>Peera Admin</h2><div class='h-1 w-20 bg-brand-500 mx-auto rounded-full'></div><p class='text-stone-400 max-w-sm mt-4 font-medium text-lg leading-relaxed transition-colors'>Advanced management and infrastructure control center.</p></div></div></div></div>" },
      "admin/dashboard": { "title": "Admin Dashboard", "html": "<div class='p-8 lg:p-12 max-w-7xl mx-auto flex flex-col gap-12'><div class='flex flex-col gap-3'><h1 class='text-4xl font-black text-stone-900 dark:text-white tracking-tighter uppercase tracking-[0.1em]'>Control Center</h1><p class='text-stone-500 font-black text-xs tracking-[0.3em] uppercase'>Infrastructure Management & Automation</p></div><div class='grid grid-cols-1 md:grid-cols-4 gap-8'><div class='p-10 bg-stone-900 border border-stone-800 rounded-[40px] shadow-2xl relative overflow-hidden group hover:scale-[1.02] transition-all'><div class='absolute top-0 right-0 w-32 h-32 bg-brand-500/10 blur-3xl rounded-full'></div><p class='text-stone-500 text-[10px] font-black uppercase tracking-[0.3em] mb-4'>Total Tenants</p><h3 class='text-5xl font-black text-white tracking-tighter'>1,284</h3></div><div class='p-10 bg-stone-900 border border-stone-800 rounded-[40px] shadow-2xl relative overflow-hidden group hover:scale-[1.02] transition-all'><p class='text-stone-500 text-[10px] font-black uppercase tracking-[0.3em] mb-4'>Active Nodes</p><h3 class='text-5xl font-black text-green-400 font-mono tracking-tighter'>99.9%</h3></div></div></div>" },
      "admin/theme": { "title": "Admin Theme Designer", "html": "<div class='min-h-screen bg-stone-50 dark:bg-black p-12 lg:p-20 flex flex-col items-center justify-center font-sans transition-colors duration-500 relative'><div class='absolute inset-0 dark:hidden shadow-[inset_0_0_200px_rgba(0,0,0,0.05)] pointer-events-none'></div><div class='w-full max-w-2xl bg-white dark:bg-[#080808] border border-stone-200 dark:border-white/5 rounded-[60px] p-16 shadow-[0_80px_200px_-50px_rgba(0,0,0,0.4)] dark:shadow-[0_100px_250px_-60px_rgba(0,0,0,1)] transition-all duration-700 relative z-10'><div class='flex flex-col gap-4 mb-14 text-center'><h1 class='text-4xl font-black text-stone-950 dark:text-white uppercase tracking-tighter'>Theme Master</h1><p class='text-stone-500 font-medium'>Control the universal layout engine from this central hub.</p></div><div class='grid grid-cols-1 gap-8'><div class='p-10 bg-stone-50 dark:bg-white/5 border border-stone-100 dark:border-white/5 rounded-[40px] flex items-center justify-between group hover:scale-[1.02] transition-all shadow-sm'><div class='flex flex-col gap-1'><h3 class='font-black text-stone-950 dark:text-white uppercase tracking-[0.2em] text-[10px]'>Live Engine</h3><p class='text-stone-500 text-xs font-medium'>Enable the floating JSON editor portal-wide.</p></div><button onclick='Peera.dev.toggle(); location.reload()' class='px-8 py-4 bg-brand-500 hover:bg-brand-600 text-white font-black text-[10px] uppercase tracking-widest rounded-2xl shadow-2xl shadow-brand-500/40 active:scale-[0.95] transition-all cursor-pointer'>Toggle Switch</button></div><div class='p-10 bg-stone-50 dark:bg-white/5 border border-stone-100 dark:border-white/5 rounded-[40px] flex items-center justify-between group hover:scale-[1.02] transition-all shadow-sm'><div class='flex flex-col gap-1'><h3 class='font-black text-stone-950 dark:text-white uppercase tracking-[0.2em] text-[10px]'>Portal Preview</h3><p class='text-stone-500 text-xs font-medium'>Launch the customer portal to test your changes.</p></div><button onclick='Peera.dev.launch(`/`)' class='px-8 py-4 bg-white dark:bg-stone-900 border border-stone-200 dark:border-white/10 text-stone-900 dark:text-white font-black text-[10px] uppercase tracking-widest rounded-2xl shadow-lg active:scale-[0.95] transition-all cursor-pointer'>Launch Preview</button></div></div><div class='mt-16 pt-10 border-t border-stone-100 dark:border-white/5 flex justify-between items-center opacity-60'><span class='text-[10px] font-black text-stone-400 uppercase tracking-[0.2em]'>Authorization: Platform Admin</span><button onclick='Peera.auth.logout()' class='text-[10px] font-black text-red-500 uppercase tracking-widest hover:underline transition-all'>Sign Out</button></div></div></div>" }
    }
  },
  "theme": { "tokens": { "colors": { "brand-500": "#465fff", "stone-950": "#0c0c0c", "stone-900": "#171717" } } }
