{
  "version": "1.0.0",
  "name": "Peera Default",
  "description": "Standard layout for all new tenants",
  "layout": {
    "nav": {
      "position": "left",
      "header_html": "<div class='p-8 pb-4 flex flex-col gap-2'><div class='inline-flex items-center gap-2'><div class='w-6 h-6 bg-brand-500 rounded-lg flex items-center justify-center text-white font-black text-[10px] shadow-lg'>P</div><span class='font-black text-stone-900 dark:text-white uppercase tracking-widest text-[10px]'>{{company_name}}</span></div><div class='h-px w-full bg-stone-100 dark:bg-white/5 mt-4'></div></div>",
      "footer_html": "<div class='p-8 pt-4'><div class='h-px w-full bg-stone-100 dark:bg-white/5 mb-4'></div><p class='text-[8px] font-black text-stone-400 uppercase tracking-[0.2em] leading-relaxed'>{{company_name}} v1.0<br/>Secure Gateway Active</p></div>",
      "items": [
        { "id": "nav.home", "label": "Home", "url": "/" },
        { "id": "nav.status", "label": "Status", "url": "/status" },
        { "id": "nav.billing", "label": "Billing", "url": "/billing" },
        { "id": "nav.docs", "label": "Documents", "url": "/documents" },
        { "id": "nav.profile", "label": "Profile", "url": "/profile" },
        { 
          "id": "nav.signout", 
          "label": "Sign Out", 
          "html": "<div class='px-4 mt-4'><button onclick='Peera.auth.logout()' class='w-full bg-red-500/10 hover:bg-red-500 text-red-500 hover:text-white py-3 rounded-2xl transition-all text-xs font-black uppercase tracking-widest cursor-pointer'>Sign Out</button></div>" 
        }
      ]
    },
    "signout": { "script": "auth.logout" },
    "contents": {
      "dashboard": { "title": "Dashboard", "html": "<div class='p-8 lg:p-12 max-w-7xl mx-auto flex flex-col gap-10'><div class='flex justify-between items-end'><div class='flex flex-col gap-2'><h1 class='text-3xl font-black text-stone-900 dark:text-white tracking-tight'>Welcome, {{tenant_name_final}}</h1><p class='text-stone-500 font-medium'>Manage your subscription and connection details.</p></div><div class='bg-green-500/10 text-green-500 px-4 py-2 rounded-xl font-bold text-xs uppercase tracking-widest border border-green-500/20 transition-all'>Status: Active</div></div><div class='grid grid-cols-1 md:grid-cols-3 gap-8'><div class='p-8 bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-[32px] shadow-xl'><p class='text-stone-500 text-[10px] font-black uppercase tracking-[0.2em] mb-2'>Outstanding Balance</p><h3 class='text-4xl font-black text-stone-950 dark:text-white'>{{currency}} 0.00</h3></div><div class='p-8 bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-[32px] shadow-xl'><p class='text-stone-500 text-[10px] font-black uppercase tracking-[0.2em] mb-2'>Connection Speed</p><h3 class='text-4xl font-black text-blue-500'>50 <span class='text-lg'>Mbps</span></h3></div><div class='p-8 bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-[32px] shadow-xl'><p class='text-stone-500 text-[10px] font-black uppercase tracking-[0.2em] mb-2'>Billing Cycle</p><h3 class='text-4xl font-black text-stone-950 dark:text-white italic'>Monthly</h3></div></div></div>" },
      "billing": { "title": "Billing", "html": "<div class='p-12 max-w-7xl mx-auto'><h1 class='text-3xl font-black text-stone-900 dark:text-white mb-8'>Billing History</h1><div class='p-20 border border-dashed border-stone-300 dark:border-stone-800 rounded-[40px] text-center text-stone-500 italic'>No invoices found for this account.</div></div>" },
      "status": { "title": "Status", "html": "<div class='p-12 max-w-7xl mx-auto'><h1 class='text-3xl font-black text-stone-900 dark:text-white mb-8'>Network Status</h1><div class='grid grid-cols-1 md:grid-cols-2 gap-8'><div class='p-8 bg-green-500/5 border border-green-500/20 rounded-[32px]'><h3 class='font-bold text-green-500'>Main Infrastructure</h3><p class='text-sm text-stone-500 mt-1 uppercase font-black tracking-widest'>Operational</p></div><div class='p-8 bg-blue-500/5 border border-blue-500/20 rounded-[32px]'><h3 class='font-bold text-blue-500'>Global Gateway</h3><p class='text-sm text-stone-500 mt-1 uppercase font-black tracking-widest'>Healthy</p></div></div></div>" },
      "login": { "title": "Sign In", "html": "<div class='flex min-h-screen bg-stone-50 dark:bg-[#050505] font-sans overflow-hidden transition-colors duration-500 text-stone-900 dark:text-white relative'><div class='absolute inset-0 dark:hidden' style='background: radial-gradient(circle, transparent 20%, rgba(0,0,0,0.05) 100%); pointer-events: none;'></div><div class='w-full lg:w-[45%] flex flex-col justify-center items-center p-12 lg:p-20 z-20 bg-white dark:bg-[#050505] border-r border-stone-200 dark:border-white/5 shadow-2xl transition-all duration-500'><div class='w-full max-sm:px-4 max-w-sm relative'><button onclick='Peera.theme.toggle()' class='absolute -top-12 right-0 p-2 bg-stone-100 dark:bg-white/5 border border-stone-200 dark:border-white/10 rounded-xl hover:scale-110 transition-all cursor-pointer'><svg class='w-5 h-5 dark:hidden text-stone-600' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z'></path></svg><svg class='w-5 h-5 hidden dark:block text-yellow-400' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z'></path></svg></button><div class='mb-12'><div class='inline-flex items-center gap-3 p-4 bg-white rounded-2xl shadow-[0_25px_60px_-15px_rgba(0,0,0,0.3)] dark:shadow-[0_40px_100px_-20px_rgba(0,0,0,1)] border border-stone-100 dark:border-transparent scale-105 transition-all'><img src='{{logo}}' alt='{{company_name}}' class='w-9 h-9 object-contain' /><div class='flex flex-col text-left'><span class='text-sm font-black text-stone-900 leading-none'>{{company_name}}</span><span class='text-[10px] text-stone-500 font-medium tracking-tight uppercase mt-1'>Customer Portal</span></div></div></div><div class='flex flex-col gap-2 mb-8'><h1 class='text-3xl font-black tracking-tight text-stone-950 dark:text-white'>Sign In</h1><p class='text-stone-500 font-medium'>Access your dashboard and subscription.</p></div><div class='flex flex-col gap-5'><div class='flex flex-col gap-2'><label class='text-xs font-black uppercase tracking-widest text-stone-400 ml-1'>Email Address</label><input id='email' type='email' placeholder='name@company.com' class='w-full p-4 bg-stone-50 dark:bg-black/20 border border-stone-200 dark:border-white/5 rounded-2xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500/50 transition-all placeholder:text-stone-400' /></div><div class='flex flex-col gap-2'><label class='text-xs font-black uppercase tracking-widest text-stone-400 ml-1'>Password</label><input id='password' type='password' placeholder='••••••••' class='w-full p-4 bg-stone-50 dark:bg-black/20 border border-stone-200 dark:border-white/5 rounded-2xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500/50 transition-all placeholder:text-stone-400' /></div><button onclick=\"Peera.auth.login('email', 'password')\" class='w-full py-4.5 bg-brand-500 hover:bg-brand-600 text-white rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-brand-500/20 active:scale-[0.98] transition-all cursor-pointer mt-4'>Enter Portal</button></div><div class='mt-10 pt-8 border-t border-stone-100 dark:border-white/5 text-center'><p class='text-xs text-stone-400 font-medium'>Forgot your password? <a href='/forgot' class='text-brand-500 font-black hover:underline underline-offset-4 ml-1'>Reset here</a></p></div></div></div><div class='hidden lg:flex flex-1 items-center justify-center bg-stone-50 dark:bg-black relative overflow-hidden transition-all duration-500'><div class='absolute inset-0 opacity-40' style=\"background-image: radial-gradient(#3b82f6 0.5px, transparent 0.5px); background-size: 24px 24px;\"></div><div class='absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-500/10 blur-[120px] rounded-full'></div><div class='relative z-10 text-center max-w-lg p-12'><div class='w-20 h-20 bg-white dark:bg-white/5 rounded-3xl shadow-2xl flex items-center justify-center mx-auto mb-10 border border-white/10'><svg class='w-10 h-10 text-brand-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'></path></svg></div><h2 class='text-4xl font-black text-stone-950 dark:text-white mb-4 tracking-tighter leading-tight'>Seamless Network Management</h2><p class='text-stone-500 text-lg font-medium leading-relaxed'>The ultimate billing and network orchestration system for modern ISPs.</p></div></div></div>" },
      "admin/login": { "title": "Admin Sign In", "html": "<div class='flex min-h-screen bg-stone-50 dark:bg-[#050505] font-sans overflow-hidden transition-colors duration-500 text-stone-900 dark:text-white relative'><div class='absolute inset-0 dark:hidden' style='background: radial-gradient(circle, transparent 20%, rgba(0,0,0,0.05) 100%); pointer-events: none;'></div><div class='w-full lg:w-[45%] flex flex-col justify-center items-center p-12 lg:p-20 z-20 bg-white dark:bg-[#050505] border-r border-stone-200 dark:border-white/5 shadow-2xl transition-all duration-500'><div class='w-full max-w-sm relative'><button onclick='Peera.theme.toggle()' class='absolute -top-12 right-0 p-2 bg-stone-100 dark:bg-white/5 border border-stone-200 dark:border-white/10 rounded-xl hover:scale-110 transition-all cursor-pointer'><svg class='w-5 h-5 dark:hidden text-stone-600' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z'></path></svg><svg class='w-5 h-5 hidden dark:block text-yellow-400' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z'></path></svg></button><div class='mb-12'><div class='inline-flex items-center gap-3 p-4 bg-stone-900 rounded-2xl shadow-[0_25px_60px_-15px_rgba(0,0,0,0.5)] border border-white/10 scale-105 transition-all'><div class='w-9 h-9 bg-brand-500 rounded-xl flex items-center justify-center text-white font-black text-xl'>A</div><div class='flex flex-col text-left'><span class='text-sm font-black text-white leading-none tracking-tight'>Peera Admin</span><span class='text-[10px] text-stone-500 font-bold tracking-widest uppercase mt-1'>Internal Access</span></div></div></div><div class='flex flex-col gap-2 mb-8'><h1 class='text-3xl font-black tracking-tight text-white'>Control Access</h1><p class='text-stone-500 font-medium'>Administrator authentication required.</p></div><div class='flex flex-col gap-5'><div class='flex flex-col gap-2'><label class='text-xs font-black uppercase tracking-widest text-stone-400 ml-1'>Admin Email</label><input id='email' type='email' placeholder='admin@peera.id' class='w-full p-4 bg-black/20 border border-white/5 rounded-2xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500/50 transition-all placeholder:text-stone-400 text-white' /></div><div class='flex flex-col gap-2'><label class='text-xs font-black uppercase tracking-widest text-stone-400 ml-1'>Secure Key</label><input id='password' type='password' placeholder='••••••••' class='w-full p-4 bg-black/20 border border-white/5 rounded-2xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500/50 transition-all placeholder:text-stone-400 text-white' /></div><button onclick=\"Peera.auth.login('email', 'password')\" class='w-full py-4.5 bg-white text-black rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-white/5 active:scale-[0.98] transition-all cursor-pointer mt-4'>Verify Credentials</button></div><div class='mt-10 pt-8 border-t border-white/5 text-center'><p class='text-xs text-stone-500 font-medium'>Protected by Peera Core Security</p></div></div></div><div class='hidden lg:flex flex-1 items-center justify-center bg-black relative overflow-hidden'><div class='absolute inset-0 opacity-20' style=\"background-image: radial-gradient(#fff 0.5px, transparent 0.5px); background-size: 32px 32px;\"></div><div class='absolute bottom-0 left-0 w-full h-full bg-gradient-to-t from-brand-500/20 to-transparent'></div><div class='relative z-10 text-center max-w-lg p-12'><div class='mb-10 inline-flex items-center gap-2 px-4 py-2 bg-red-500/10 border border-red-500/20 rounded-full'><div class='w-2 h-2 bg-red-500 rounded-full animate-pulse'></div><span class='text-[10px] font-black text-red-500 uppercase tracking-widest'>Admin Terminal</span></div><h2 class='text-5xl font-black text-white mb-6 tracking-tighter leading-[0.9] uppercase italic'>System<br/>Orchestrator</h2><p class='text-stone-500 text-lg font-medium leading-relaxed'>Manage global infrastructure, tenants, and system-wide design schemas.</p></div></div></div>" },
      "admin/dashboard": { "title": "Admin Dashboard", "html": "<div class='p-8 lg:p-12 max-w-7xl mx-auto flex flex-col gap-12'><div class='flex flex-col gap-3'><h1 class='text-4xl font-black text-stone-900 dark:text-white tracking-tighter uppercase tracking-[0.1em]'>Control Center</h1><p class='text-stone-500 font-black text-xs tracking-[0.3em] uppercase'>Infrastructure Management & Automation</p></div><div class='grid grid-cols-1 md:grid-cols-4 gap-8'><div class='p-10 bg-stone-900 border border-stone-800 rounded-[40px] shadow-2xl relative overflow-hidden group hover:scale-[1.02] transition-all'><div class='absolute top-0 right-0 w-32 h-32 bg-brand-500/10 blur-3xl rounded-full'></div><p class='text-stone-500 text-[10px] font-black uppercase tracking-[0.3em] mb-4'>Total Tenants</p><h3 class='text-5xl font-black text-white tracking-tighter'>1,284</h3></div><div class='p-10 bg-stone-900 border border-stone-800 rounded-[40px] shadow-2xl relative overflow-hidden group hover:scale-[1.02] transition-all'><p class='text-stone-500 text-[10px] font-black uppercase tracking-[0.3em] mb-4'>Active Nodes</p><h3 class='text-5xl font-black text-green-400 font-mono tracking-tighter'>99.9%</h3></div></div></div>" },
      "admin/theme": {
        "title": "Admin Theme Designer",
        "html": "<div class='min-h-screen bg-white dark:bg-[#050505] font-sans flex flex-col items-center justify-center p-8 lg:p-20 relative overflow-hidden transition-colors duration-500'><!-- Premium Grid --><div class='absolute inset-0 premium-grid opacity-[0.4] dark:opacity-[0.1]'></div><!-- Cyber Glow --><div class='absolute top-0 left-0 w-[600px] h-[600px] bg-brand-500/10 blur-[150px] rounded-full -translate-x-1/2 -translate-y-1/2 opacity-0 dark:opacity-50 transition-opacity duration-1000'></div><div class='absolute bottom-0 right-0 w-[600px] h-[600px] bg-blue-600/5 blur-[150px] rounded-full translate-x-1/2 translate-y-1/2 opacity-0 dark:opacity-30 transition-opacity duration-1000'></div><div class='w-full max-w-5xl relative z-10'><div class='flex flex-col gap-4 mb-16 text-center'><h1 class='text-7xl font-black text-stone-950 dark:text-white uppercase tracking-[0.2em] italic transition-all hover:tracking-[0.25em] duration-1000'>Theme Studio</h1><div class='h-1.5 w-48 bg-gradient-to-r from-transparent via-brand-500 to-transparent mx-auto rounded-full mt-2 shadow-[0_10px_30px_-5px_rgba(59,130,246,0.5)]'></div><p class='text-stone-500 font-black uppercase tracking-[0.6em] text-[9px] mt-8 opacity-70'>Architecting the Future of Network UI</p></div><div class='grid grid-cols-1 md:grid-cols-2 gap-12'><div class='group p-14 bg-white/40 dark:bg-white/5 backdrop-blur-2xl border border-stone-200 dark:border-white/10 rounded-[60px] hover:border-brand-500/40 transition-all duration-700 shadow-2xl shadow-black/5 dark:shadow-3xl relative overflow-hidden'><div class='absolute -top-10 -right-10 w-40 h-40 bg-brand-500/5 blur-3xl rounded-full group-hover:scale-150 transition-transform duration-1000'></div><div class='flex flex-col gap-10 relative z-10'><div class='w-20 h-20 bg-stone-100 dark:bg-brand-500/20 rounded-[28px] flex items-center justify-center text-stone-950 dark:text-brand-500 group-hover:rotate-6 transition-all duration-500 shadow-xl shadow-black/5'><svg class='w-10 h-10' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4'></path></svg></div><div class='flex flex-col gap-4'><h2 class='text-2xl font-black text-stone-950 dark:text-white uppercase tracking-widest'>Live Engine</h2><p class='text-sm text-stone-500 leading-relaxed font-medium'>Experience real-time UI orchestration. Inject dynamic schemas and validate your vision instantly.</p></div><button class='w-full py-6 bg-stone-950 dark:bg-white text-white dark:text-black rounded-[30px] text-[11px] font-black uppercase tracking-[0.3em] transition-all active:scale-95 shadow-2xl shadow-black/20 dark:shadow-white/10 hover:shadow-brand-500/20'>Initiate Engine</button></div></div><div class='group p-14 bg-white/40 dark:bg-white/5 backdrop-blur-2xl border border-stone-200 dark:border-white/10 rounded-[60px] hover:border-blue-500/40 transition-all duration-700 shadow-2xl shadow-black/5 dark:shadow-3xl relative overflow-hidden'><div class='absolute -bottom-10 -left-10 w-40 h-40 bg-blue-600/5 blur-3xl rounded-full group-hover:scale-150 transition-transform duration-1000'></div><div class='flex flex-col gap-10 relative z-10'><div class='w-20 h-20 bg-stone-100 dark:bg-blue-600/20 rounded-[28px] flex items-center justify-center text-stone-950 dark:text-blue-400 group-hover:-rotate-6 transition-all duration-500 shadow-xl shadow-black/5'><svg class='w-10 h-10' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'></path><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'></path></svg></div><div class='flex flex-col gap-4'><h2 class='text-2xl font-black text-stone-950 dark:text-white uppercase tracking-widest'>Portal Preview</h2><p class='text-sm text-stone-500 leading-relaxed font-medium'>Step into your customer's world. Preview the complete journey with the latest architectural layout.</p></div><button class='w-full py-6 bg-blue-600 text-white rounded-[30px] text-[11px] font-black uppercase tracking-[0.3em] transition-all active:scale-95 shadow-2xl shadow-blue-600/30 hover:shadow-blue-600/50'>Launch Portal</button></div></div></div><div class='mt-24 pt-10 border-t border-stone-200 dark:border-white/10 flex justify-between items-center'><div class='flex items-center gap-4'><div class='w-2.5 h-2.5 bg-green-500 rounded-full animate-ping absolute'></div><div class='w-2.5 h-2.5 bg-green-500 rounded-full relative'></div><span class='text-[10px] font-black uppercase tracking-[0.3em] text-stone-950 dark:text-white opacity-40'>System Status: Verified</span></div><div class='flex gap-8'><span class='text-[9px] font-black uppercase tracking-[0.3em] text-stone-400 hover:text-stone-950 dark:hover:text-white cursor-pointer transition-colors'>Documentation</span><span class='text-[9px] font-black uppercase tracking-[0.3em] text-red-500/50 hover:text-red-500 cursor-pointer transition-colors'>Emergency Kill-Switch</span></div></div></div></div>"
      }
    }
  },
  "theme": { "tokens": { "colors": { "brand-500": "#465fff", "stone-950": "#0c0c0c", "stone-900": "#171717" } } }
}
