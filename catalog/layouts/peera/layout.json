{
  "version": "1.0.0",
  "name": "Peera Default",
  "description": "Standard layout for all new tenants",
  "layout": {
    "nav": {
      "items": [
        { "id": "nav.home", "label": "Home", "url": "/" },
        { "id": "nav.status", "label": "Status", "url": "/status" },
        { "id": "nav.billing", "label": "Billing", "url": "/billing" },
        { "id": "nav.docs", "label": "Documents", "url": "/documents" },
        { "id": "nav.profile", "label": "Profile", "url": "/profile" },
        { "id": "nav.security", "label": "Security", "url": "/security/change-password" },
        { 
          "id": "nav.signout", 
          "label": "Sign Out", 
          "html": "<button onclick=\"Peera.auth.logout()\" class='w-full mt-4 bg-red-900/20 hover:bg-red-900/40 text-red-400 p-2 rounded-lg transition-colors text-sm font-medium'>Sign Out</button>" 
        }
      ]
    },
    "signout": {
      "script": "auth.logout"
    },
    "contents": {
      "dashboard": {
        "title": "Dashboard",
        "html": "<div class='p-8 bg-stone-900 border border-stone-800 rounded-xl'><h1 class='text-2xl font-bold text-white'>Dashboard</h1></div>"
      },
      "billing": {
        "title": "Billing",
        "html": "<div class='p-8 bg-stone-900 border border-stone-800 rounded-xl'><h1 class='text-2xl font-bold text-white'>Billing</h1></div>"
      },
      "login": {
        "title": "Sign In",
        "html": "<div class='flex justify-center items-center min-h-screen p-6 bg-black'><div class='w-full max-w-md bg-stone-900 border border-stone-800 rounded-3xl shadow-2xl p-10 flex flex-col gap-8'><div class='flex flex-col gap-2'><h1 class='text-3xl font-bold text-white tracking-tight'>Sign In</h1><p class='text-stone-500 text-sm'>Enter your credentials to access your billing portal.</p></div><div class='flex flex-col gap-6'><div class='flex flex-col gap-2'><label for='email' class='text-xs font-bold text-stone-400 uppercase tracking-widest'>Email Address</label><input type='email' id='email' placeholder='name@company.com' class='w-full p-4 bg-stone-950 border border-stone-800 rounded-2xl text-white placeholder-stone-700 outline-none focus:ring-2 focus:ring-brand-500/50 focus:border-brand-500 transition-all' /></div><div class='flex flex-col gap-2'><div class='flex justify-between items-center'><label for='password' class='text-xs font-bold text-stone-400 uppercase tracking-widest'>Password</label><a href='#' class='text-xs text-brand-500 hover:text-brand-400 font-medium'>Forgot password?</a></div><input type='password' id='password' placeholder='••••••••' class='w-full p-4 bg-stone-950 border border-stone-800 rounded-2xl text-white placeholder-stone-700 outline-none focus:ring-2 focus:ring-brand-500/50 focus:border-brand-500 transition-all' /></div></div><div class='flex flex-col gap-4 mt-2'><button onclick=\"Peera.auth.login('email', 'password')\" class='w-full py-4 bg-brand-500 hover:bg-brand-600 text-white font-bold rounded-2xl shadow-xl shadow-brand-500/20 active:scale-[0.98] transition-all cursor-pointer'>Sign In to Portal</button><div class='flex items-center gap-4 py-2'><div class='h-px flex-1 bg-stone-800'></div><span class='text-[10px] text-stone-600 uppercase font-bold tracking-widest'>or</span><div class='h-px flex-1 bg-stone-800'></div></div><button class='w-full py-3.5 bg-stone-950 border border-stone-800 text-stone-400 text-sm font-semibold rounded-2xl hover:bg-stone-800 transition-all cursor-not-allowed opacity-50'>Sign In with SSO</button></div><p class='text-xs text-center text-stone-600 mt-2'>Don't have an account? <a href='/register' class='text-stone-400 hover:text-white hover:underline transition-colors'>Register here</a></p></div></div>"
      }
    }
  },
  "theme": {
    "tokens": {
      "colors": {
        "brand-500": "#465fff",
        "stone-950": "#0c0c0c",
        "stone-900": "#171717"
      }
    }
  }
}