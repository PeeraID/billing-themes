{
  "version": "1.0.0",
  "name": "Peera Default",
  "description": "Standard layout for all new tenants",
  "layout": {
    "nav": {
      "position": "left",
      "header_html": "<div class='p-6 pb-4 flex flex-col gap-4'><div class='inline-flex items-center gap-3'><div class='w-9 h-9 bg-brand-500 rounded-xl flex items-center justify-center flex-shrink-0 overflow-hidden'><img src='{{global.logo}}' alt='' class='w-full h-full object-contain' onerror=\"this.style.display='none';this.nextElementSibling.style.display='flex'\" /><span style='display:none' class='w-full h-full items-center justify-center text-white font-black text-sm'>{{global.slug}}</span></div><div class='flex flex-col min-w-0'><span class='font-black text-gray-900 dark:text-white uppercase tracking-tighter text-xs truncate'>{{global.company_name}}</span><span class='text-[8px] font-bold text-brand-500 uppercase tracking-widest'>Portal</span></div></div><div class='h-px w-full bg-gray-200 dark:bg-gray-800 mt-2'></div></div>",
      "footer_html": "<div class='p-5 pt-4'><div class='h-px w-full bg-gray-200 dark:bg-gray-800 mb-4'></div><div class='flex flex-col gap-0.5'><p class='text-[8px] font-bold text-gray-500 uppercase tracking-[0.2em]'>{{global.company_name}} &copy; 2026</p><p class='text-[7px] font-medium text-gray-400'>Powered by Peera System</p></div></div>",
      "topbar_html": "<div class='px-6 py-3 flex items-center gap-2'><span class='text-xs font-bold text-gray-500 dark:text-gray-400'>Welcome,</span><span class='text-xs font-black text-gray-900 dark:text-white'>{{global.customer_fullname}}</span></div>",
      "items": [
        {
          "id": "nav.home",
          "label": "Dashboard",
          "url": "/"
        },
        {
          "id": "nav.status",
          "label": "Network Status",
          "url": "/status"
        },
        {
          "id": "nav.billing",
          "label": "Billing & Invoices",
          "url": "/billing"
        },
        {
          "id": "nav.support",
          "label": "Support",
          "url": "/support"
        },
        {
          "id": "nav.docs",
          "label": "Documents",
          "url": "/documents"
        },
        {
          "id": "nav.profile",
          "label": "My Profile",
          "url": "/profile"
        }
      ]
    },
    "signout": {
      "script": "auth.logout"
    },
    "contents": {
      "dashboard": {
        "title": "Overview",
        "html": "<div class='p-6 lg:p-8 max-w-7xl mx-auto flex flex-col gap-8'><div class='flex flex-col gap-1'><p class='text-brand-500 font-bold uppercase tracking-widest text-[10px]'>Welcome back</p><h1 class='text-2xl font-black text-gray-900 dark:text-white tracking-tight'>{{global.customer_fullname}}</h1><p class='text-sm text-gray-500 dark:text-gray-400'>Here's what's happening with your account.</p></div><div class='grid grid-cols-1 md:grid-cols-3 gap-5'><div class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] p-5 md:p-6 flex flex-col gap-4'><div class='flex items-center justify-between'><span class='text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Network Status</span><span class='w-2 h-2 rounded-full bg-emerald-500'></span></div><div class='flex flex-col gap-1'><h3 class='text-xl font-black text-gray-900 dark:text-white'>{{status.status}}</h3><p class='text-sm text-gray-500 dark:text-gray-400'>IP: {{status.active_ip}}</p></div></div><div class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] p-5 md:p-6 flex flex-col gap-4'><div class='flex items-center justify-between'><span class='text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Current Plan</span><span class='w-2 h-2 rounded-full bg-brand-500'></span></div><div class='flex flex-col gap-1'><h3 class='text-xl font-black text-gray-900 dark:text-white'>{{status.service_plan}}</h3><p class='text-sm text-gray-500 dark:text-gray-400'>Monthly subscription</p></div></div><div class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] p-5 md:p-6 flex flex-col gap-4'><div class='flex items-center justify-between'><span class='text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Outstanding</span><span id='dash-bill-dot' class='w-2 h-2 rounded-full bg-amber-500'></span></div><div class='flex flex-col gap-1'><h3 id='dash-bill-amount' class='text-xl font-black text-gray-900 dark:text-white'>{{global.currency}} {{billing.total_amount}}</h3><p id='dash-bill-due' class='text-sm text-gray-500 dark:text-gray-400'>Due: {{billing.due_date}}</p></div><script>if('{{billing.invoice_number}}'==='—'){document.getElementById('dash-bill-amount').textContent='All Paid';document.getElementById('dash-bill-due').textContent='No outstanding invoices';document.getElementById('dash-bill-dot').className='w-2 h-2 rounded-full bg-emerald-500';}</script></div></div><div class='grid grid-cols-1 lg:grid-cols-2 gap-5'><div class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] p-5 md:p-6 flex flex-col gap-5'><div class='flex items-center justify-between'><h3 class='text-sm font-black text-gray-900 dark:text-white uppercase tracking-widest'>Latest Invoice</h3><span class='px-3 py-1 text-[10px] font-bold rounded-full bg-amber-50 dark:bg-amber-500/10 text-amber-600 dark:text-amber-400 border border-amber-200 dark:border-amber-500/20'>{{billing.status}}</span></div><div class='flex flex-col gap-2'><p class='text-xs text-gray-500 dark:text-gray-400'>Invoice #{{billing.invoice_number}}</p><p class='text-2xl font-black text-gray-900 dark:text-white'>{{global.currency}} {{billing.total_amount}}</p></div><a href='{{billing.payment_url}}' class='inline-flex items-center gap-2 px-4 py-2.5 bg-brand-500 hover:bg-brand-600 text-white rounded-xl text-xs font-bold uppercase tracking-widest transition-all cursor-pointer w-fit'>Pay Now &rarr;</a></div><div class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] p-5 md:p-6 flex flex-col gap-5'><div class='flex items-center justify-between'><h3 class='text-sm font-black text-gray-900 dark:text-white uppercase tracking-widest'>Support</h3><span class='px-3 py-1 text-[10px] font-bold rounded-full bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/20'>{{support.status}}</span></div><div class='flex flex-col gap-2'><p class='text-xs text-gray-500 dark:text-gray-400'>Ticket #{{support.ticket_number}}</p><p class='text-sm font-bold text-gray-900 dark:text-white'>{{support.title}}</p></div><p class='text-xs text-gray-500 dark:text-gray-400'>Created: {{support.created_at}}</p></div></div></div>"
      },
      "billing": {
        "title": "Billing",
        "html": "<div class='p-6 lg:p-8 max-w-7xl mx-auto flex flex-col gap-8'><div class='flex items-end justify-between'><div class='flex flex-col gap-1'><h1 class='text-2xl font-black text-gray-900 dark:text-white tracking-tight'>Billing & Invoices</h1><p class='text-sm text-gray-500 dark:text-gray-400'>Manage your billing history and settle payments.</p></div></div><div id='billing-card' class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] overflow-hidden'><div class='px-6 py-4 border-b border-gray-200 dark:border-gray-800 flex items-center justify-between'><div class='flex flex-col gap-0.5'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Latest Invoice</span><span class='text-sm font-bold text-gray-900 dark:text-white'>#{{billing.invoice_number}}</span></div><span class='px-3 py-1 text-[10px] font-bold rounded-full bg-amber-50 dark:bg-amber-500/10 text-amber-600 dark:text-amber-400 border border-amber-200 dark:border-amber-500/20 uppercase tracking-wide'>{{billing.status}}</span></div><div class='p-6 flex flex-col gap-8'><div class='grid grid-cols-2 md:grid-cols-4 gap-6'><div class='flex flex-col gap-1'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Invoice Date</span><span class='text-sm font-bold text-gray-900 dark:text-white'>{{billing.invoice_date}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Due Date</span><span class='text-sm font-bold text-red-500'>{{billing.due_date}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Tax ({{billing.tax_rate}}%)</span><span class='text-sm font-bold text-gray-900 dark:text-white'>{{global.currency}} {{billing.tax_amount}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Total Amount</span><span class='text-xl font-black text-brand-500'>{{global.currency}} {{billing.total_amount}}</span></div></div><div class='grid grid-cols-2 md:grid-cols-4 gap-6 pt-4 border-t border-gray-100 dark:border-gray-800'><div class='flex flex-col gap-1'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Period Start</span><span class='text-sm font-bold text-gray-900 dark:text-white'>{{billing.period_start}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Period End</span><span class='text-sm font-bold text-gray-900 dark:text-white'>{{billing.period_end}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Payment Method</span><span class='text-sm font-bold text-gray-900 dark:text-white'>{{billing.payment_method}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Payment Date</span><span class='text-sm font-bold text-gray-900 dark:text-white'>{{billing.payment_date}}</span></div></div><div class='flex gap-3 pt-2'><button onclick='window.open(\"{{billing.payment_url}}\")' class='flex-1 py-3 bg-brand-500 hover:bg-brand-600 text-white rounded-xl text-xs font-bold uppercase tracking-widest transition-all shadow-sm cursor-pointer'>Pay Now &rarr;</button><button class='px-6 py-3 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-gray-200 dark:hover:bg-gray-700 transition-all cursor-pointer'>Download PDF</button></div></div></div><div id='billing-empty' style='display:none' class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] p-12 flex flex-col items-center justify-center gap-4 text-center'><div class='w-14 h-14 bg-emerald-50 dark:bg-emerald-500/10 rounded-2xl flex items-center justify-center text-emerald-500'><svg xmlns='http://www.w3.org/2000/svg' width='28' height='28' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='20 6 9 17 4 12'/></svg></div><div class='flex flex-col gap-1'><h3 class='text-base font-black text-gray-900 dark:text-white'>All Paid Up</h3><p class='text-sm text-gray-500 dark:text-gray-400'>No outstanding invoices. Your account is in good standing.</p></div></div><script>if('{{billing.invoice_number}}'==='—'){document.getElementById('billing-card').style.display='none';document.getElementById('billing-empty').style.display='flex';}</script></div>"
      },
      "status": {
        "title": "Network Status",
        "html": "<div class='p-6 lg:p-8 max-w-7xl mx-auto flex flex-col gap-8'><div class='flex flex-col gap-1'><h1 class='text-2xl font-black text-gray-900 dark:text-white tracking-tight'>Network Status</h1><p class='text-sm text-gray-500 dark:text-gray-400'>Real-time infrastructure health and connection details.</p></div><div class='grid grid-cols-1 md:grid-cols-2 gap-5'><div class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] p-5 md:p-6 flex flex-col gap-5'><div class='flex items-center justify-between'><h3 class='text-sm font-black text-gray-900 dark:text-white uppercase tracking-widest'>Service Status</h3><div class='flex items-center gap-2'><span class='relative flex w-2 h-2'><span class='animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75'></span><span class='relative inline-flex rounded-full w-2 h-2 bg-emerald-500'></span></span><span class='text-[10px] font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-widest'>Active</span></div></div><div class='h-1 w-full bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden'><div class='h-full bg-emerald-500 rounded-full w-full'></div></div><div class='flex flex-col gap-1'><p class='text-3xl font-black text-gray-900 dark:text-white'>{{status.status}}</p><p class='text-sm text-gray-500 dark:text-gray-400'>No incidents in the last 24 hours.</p></div></div><div class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] p-5 md:p-6 flex flex-col gap-5'><div class='flex items-center justify-between'><h3 class='text-sm font-black text-gray-900 dark:text-white uppercase tracking-widest'>Connectivity</h3><span class='text-[10px] font-bold text-brand-500 uppercase tracking-widest'>{{status.is_online}}</span></div><div class='flex flex-col gap-3'><div class='flex flex-col gap-1'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Active IP</span><span class='text-sm font-mono font-bold text-gray-900 dark:text-white'>{{status.active_ip}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Service Plan</span><span class='text-xl font-black text-gray-900 dark:text-white'>{{status.service_plan}}</span></div></div></div></div></div>"
      },
      "profile": {
        "title": "My Profile",
        "html": "<div class='p-6 lg:p-8 max-w-7xl mx-auto flex flex-col gap-8'><div class='flex items-end justify-between'><div class='flex flex-col gap-1'><h1 class='text-2xl font-black text-gray-900 dark:text-white tracking-tight'>My Profile</h1><p class='text-sm text-gray-500 dark:text-gray-400'>Manage your personal information and subscription.</p></div><button onclick='window.Peera.design.launch(\"/profile\")' class='px-4 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-xs font-bold text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-all cursor-pointer'>Edit Profile</button></div><div class='grid grid-cols-1 lg:grid-cols-3 gap-5'><div class='lg:col-span-2 flex flex-col gap-5'><div class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] p-5 md:p-6 flex flex-col gap-6'><h3 class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Personal Information</h3><div class='grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-5'><div class='flex flex-col gap-1'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Full Name</span><span class='text-sm font-bold text-gray-900 dark:text-white'>{{profile.fullname}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Customer ID</span><span class='text-sm font-mono font-bold text-brand-500'>{{profile.cust_id}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>WhatsApp</span><span class='text-sm font-bold text-gray-900 dark:text-white'>{{profile.whatsapp}}</span></div><div class='flex flex-col gap-1'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Email Address</span><span class='text-sm font-bold text-gray-900 dark:text-white'>{{profile.email}}</span></div></div><div class='h-px w-full bg-gray-100 dark:bg-gray-800'></div><div class='flex flex-col gap-1'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Installation Address</span><span class='text-sm font-bold text-gray-900 dark:text-white leading-relaxed'>{{profile.address}}</span></div></div><div class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] overflow-hidden flex flex-col'><div class='p-5 md:p-6 flex items-center justify-between'><h3 class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Installation Location</h3><div class='flex items-center gap-3'><span class='text-[10px] font-mono text-gray-400'>{{profile.latitude}}, {{profile.longitude}}</span><a href='https://www.google.com/maps?q={{profile.latitude}},{{profile.longitude}}' target='_blank' class='px-3 py-1.5 bg-brand-500/10 text-brand-500 hover:bg-brand-500 hover:text-white rounded-lg text-[10px] font-bold uppercase tracking-widest transition-all'>Open Maps</a></div></div><div class='h-52 w-full'><iframe src='https://www.google.com/maps?q={{profile.latitude}},{{profile.longitude}}&z=16&output=embed' width='100%' height='100%' style='border:0;display:block' allowfullscreen loading='lazy' referrerpolicy='no-referrer-when-downgrade'></iframe></div></div></div><div class='flex flex-col gap-5'><div class='rounded-2xl bg-brand-500 p-5 md:p-6 flex flex-col gap-4'><span class='text-[10px] font-bold text-white/60 uppercase tracking-widest'>Active Plan</span><h3 class='text-xl font-black text-white'>{{profile.service_plan}}</h3><span class='px-3 py-1 bg-white/10 border border-white/20 text-white rounded-full text-[10px] font-bold uppercase tracking-widest w-fit'>{{profile.status}}</span></div><div class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] p-5 md:p-6 flex flex-col gap-4'><h3 class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Coverage Region</h3><div class='flex items-center gap-3'><div class='w-9 h-9 bg-brand-500/10 rounded-lg flex items-center justify-center text-brand-500 flex-shrink-0'><svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z'/><circle cx='12' cy='10' r='3'/></svg></div><span class='text-sm font-bold text-gray-900 dark:text-white'>{{profile.region}}</span></div></div></div></div></div>"
      },
      "documents": {
        "title": "Documents",
        "html": "<div class='p-6 lg:p-8 max-w-7xl mx-auto flex flex-col gap-8'><div class='flex flex-col gap-1'><h1 class='text-2xl font-black text-gray-900 dark:text-white tracking-tight'>Documents</h1><p class='text-sm text-gray-500 dark:text-gray-400'>Access your contracts, agreements, and service documents.</p></div><div id='docs-list' class='grid grid-cols-1 md:grid-cols-2 gap-4'><div class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] p-5 flex items-center justify-between group hover:border-brand-500/50 transition-all'><div class='flex items-center gap-4'><div class='w-12 h-12 bg-gray-100 dark:bg-gray-800 rounded-xl flex items-center justify-center text-gray-400 group-hover:text-brand-500 transition-colors'><svg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z'/><polyline points='14 2 14 8 20 8'/></svg></div><div class='flex flex-col gap-0.5'><span class='text-sm font-bold text-gray-900 dark:text-white'>{{documents.name}}</span><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>PDF &bull; Verified</span></div></div><a href='{{documents.file_url}}' target='_blank' class='w-9 h-9 bg-brand-500/10 text-brand-500 rounded-lg flex items-center justify-center hover:bg-brand-500 hover:text-white transition-all flex-shrink-0'><svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4'/><polyline points='7 10 12 15 17 10'/><line x1='12' x2='12' y1='15' y2='3'/></svg></a></div></div><div id='docs-empty' style='display:none' class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] p-12 flex flex-col items-center justify-center gap-4 text-center'><div class='w-14 h-14 bg-gray-100 dark:bg-gray-800 rounded-2xl flex items-center justify-center text-gray-400'><svg xmlns='http://www.w3.org/2000/svg' width='28' height='28' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z'/><polyline points='14 2 14 8 20 8'/></svg></div><div class='flex flex-col gap-1'><h3 class='text-base font-black text-gray-900 dark:text-white'>No Documents Yet</h3><p class='text-sm text-gray-500 dark:text-gray-400'>Your contracts and agreements will appear here once available.</p></div></div><script>if('{{documents.name}}'==='—'){document.getElementById('docs-list').style.display='none';document.getElementById('docs-empty').style.display='flex';}</script></div>"
      },
      "support": {
        "title": "Support",
        "html": "<div class='p-6 lg:p-8 max-w-7xl mx-auto flex flex-col gap-8'><div class='flex items-end justify-between'><div class='flex flex-col gap-1'><h1 class='text-2xl font-black text-gray-900 dark:text-white tracking-tight'>Help & Support</h1><p class='text-sm text-gray-500 dark:text-gray-400'>Track your tickets or request technical assistance.</p></div><a href='https://wa.me/{{profile.whatsapp}}?text=Halo,%20saya%20ingin%20membuka%20tiket%20support' target='_blank' class='px-4 py-2 bg-brand-500 hover:bg-brand-600 text-white rounded-xl text-xs font-bold uppercase tracking-widest shadow-sm transition-all cursor-pointer inline-flex items-center gap-2'><svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='currentColor'><path d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z'/></svg>Open Ticket</a></div><div id='support-card' class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] overflow-hidden'><div class='px-6 py-4 border-b border-gray-200 dark:border-gray-800'><h3 class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Active Tickets</h3></div><div class='p-5'><div class='rounded-xl border border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-800/30 p-5 flex items-start justify-between group hover:border-brand-500/30 transition-all'><div class='flex flex-col gap-3 flex-1'><div class='flex items-center gap-3 flex-wrap'><span class='px-2 py-0.5 bg-brand-500 text-white rounded text-[9px] font-bold uppercase tracking-widest'>#{{support.ticket_number}}</span><h4 class='text-sm font-bold text-gray-900 dark:text-white'>{{support.title}}</h4></div><p class='text-xs text-gray-500 dark:text-gray-400 leading-relaxed'>{{support.description}}</p><div class='flex items-center gap-6 flex-wrap'><div class='flex flex-col gap-0.5'><span class='text-[10px] font-bold text-gray-400 uppercase tracking-widest'>Type</span><span class='text-xs font-bold text-gray-700 dark:text-gray-300'>{{support.type}}</span></div><div class='flex flex-col gap-0.5'><span class='text-[10px] font-bold text-gray-400 uppercase tracking-widest'>Priority</span><span class='text-xs font-bold text-gray-700 dark:text-gray-300'>{{support.priority}}</span></div><div class='flex flex-col gap-0.5'><span class='text-[10px] font-bold text-gray-400 uppercase tracking-widest'>Created</span><span class='text-xs font-bold text-gray-700 dark:text-gray-300'>{{support.created_at}}</span></div><div class='flex flex-col gap-0.5'><span class='text-[10px] font-bold text-gray-400 uppercase tracking-widest'>Schedule</span><span class='text-xs font-bold text-brand-500'>{{support.scheduled_at}}</span></div></div></div><span class='ml-4 mt-0.5 flex-shrink-0 px-3 py-1 bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 rounded-full text-[9px] font-bold uppercase tracking-widest border border-emerald-200 dark:border-emerald-500/20'>{{support.status}}</span></div></div></div><div id='support-empty' style='display:none' class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] p-12 flex flex-col items-center justify-center gap-4 text-center'><div class='w-14 h-14 bg-brand-500/10 rounded-2xl flex items-center justify-center text-brand-500'><svg xmlns='http://www.w3.org/2000/svg' width='28' height='28' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z'/></svg></div><div class='flex flex-col gap-1'><h3 class='text-base font-black text-gray-900 dark:text-white'>No Active Tickets</h3><p class='text-sm text-gray-500 dark:text-gray-400'>Everything looks good. Click \"Open Ticket\" if you need assistance.</p></div></div><script>if('{{support.ticket_number}}'==='—'){document.getElementById('support-card').style.display='none';document.getElementById('support-empty').style.display='flex';}</script></div>"
      },
      "login": {
        "title": "Sign In",
        "html": "<div class='flex min-h-screen bg-gray-50 dark:bg-gray-900 font-sans overflow-hidden'><div class='w-full lg:w-[45%] flex flex-col justify-center items-center p-10 lg:p-16 z-20 bg-white dark:bg-gray-900 border-r border-gray-200 dark:border-gray-800'><div class='w-full max-w-sm'><div class='mb-10'><div class='inline-flex items-center gap-3 px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl'><img src='{{global.logo}}' alt='{{global.company_name}}' class='w-8 h-8 object-contain' /><div class='flex flex-col text-left'><span class='text-sm font-black text-gray-900 dark:text-white leading-none uppercase tracking-tight'>{{global.company_name}}</span><span class='text-[10px] text-gray-500 dark:text-gray-400 font-medium tracking-tight uppercase mt-0.5'>Customer Portal</span></div></div></div><div class='flex flex-col gap-1 mb-8'><h1 class='text-2xl font-black tracking-tight text-gray-900 dark:text-white'>Sign In</h1><p class='text-sm text-gray-500 dark:text-gray-400'>Access your dashboard and subscription.</p></div><div class='flex flex-col gap-5'><div class='flex flex-col gap-1.5'><label class='text-xs font-bold text-gray-600 dark:text-gray-400'>Email Address</label><input id='email' type='email' placeholder='name@company.com' class='w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-all placeholder:text-gray-400 text-gray-900 dark:text-white text-sm' /></div><div class='flex flex-col gap-1.5'><label class='text-xs font-bold text-gray-600 dark:text-gray-400'>Password</label><input id='password' type='password' placeholder='••••••••' class='w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-all placeholder:text-gray-400 text-gray-900 dark:text-white text-sm' /></div><button onclick=\"Peera.auth.login('email', 'password')\" class='w-full py-3 bg-brand-500 hover:bg-brand-600 text-white rounded-xl font-bold uppercase tracking-widest text-sm shadow-sm transition-all cursor-pointer mt-2'>Sign In</button></div><div class='mt-8 pt-6 border-t border-gray-100 dark:border-gray-800 text-center'><p class='text-xs text-gray-400 dark:text-gray-500'>Secure connection &bull; Protected by Peera</p></div><div class='mt-4 text-right'><button onclick='Peera.theme.toggle()' class='p-2 bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:scale-105 transition-all cursor-pointer'><svg class='w-4 h-4 dark:hidden text-gray-600' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z'></path></svg><svg class='w-4 h-4 hidden dark:block text-yellow-400' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z'></path></svg></button></div></div></div><div class='hidden lg:flex flex-1 items-center justify-center bg-gray-50 dark:bg-gray-950 relative overflow-hidden'><div class='absolute inset-0 opacity-30 dark:opacity-10' style=\"background-image: radial-gradient(#94a3b8 0.5px, transparent 0.5px); background-size: 24px 24px;\"></div><div class='absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-brand-500/10 dark:bg-brand-500/5 blur-[100px] rounded-full'></div><div class='relative z-10 text-center max-w-md p-10'><div class='w-16 h-16 bg-white dark:bg-gray-800 rounded-2xl shadow-lg flex items-center justify-center mx-auto mb-8 border border-gray-200 dark:border-gray-700'><svg class='w-8 h-8 text-brand-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'></path></svg></div><h2 class='text-3xl font-black text-gray-900 dark:text-white mb-3 tracking-tight'>Network Management<br/>Made Simple</h2><p class='text-gray-500 dark:text-gray-400 text-sm font-medium leading-relaxed'>The complete billing and network management system for modern ISPs.</p></div></div></div>"
      },
      "admin/login": {
        "title": "Admin Sign In",
        "html": "<div class='flex min-h-screen bg-gray-50 dark:bg-gray-900 font-sans overflow-hidden'><div class='w-full lg:w-[45%] flex flex-col justify-center items-center p-10 lg:p-16 z-20 bg-white dark:bg-gray-900 border-r border-gray-200 dark:border-gray-800'><div class='w-full max-w-sm'><div class='mb-10'><div class='inline-flex items-center gap-3 px-4 py-3 bg-gray-900 dark:bg-gray-800 rounded-2xl border border-gray-700'><div class='w-8 h-8 bg-brand-500 rounded-lg flex items-center justify-center text-white font-black text-sm'>A</div><div class='flex flex-col text-left'><span class='text-sm font-black text-white leading-none tracking-tight uppercase'>{{global.company_name}}</span><span class='text-[10px] text-gray-400 font-bold tracking-widest uppercase mt-0.5'>Admin Access</span></div></div></div><div class='flex flex-col gap-1 mb-8'><h1 class='text-2xl font-black tracking-tight text-gray-900 dark:text-white'>Admin Sign In</h1><p class='text-sm text-gray-500 dark:text-gray-400'>Administrator authentication required.</p></div><div class='flex flex-col gap-5'><div class='flex flex-col gap-1.5'><label class='text-xs font-bold text-gray-600 dark:text-gray-400'>Admin Email</label><input id='email' type='email' placeholder='admin@{{global.tenant_code}}.id' class='w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-all placeholder:text-gray-400 text-gray-900 dark:text-white text-sm' /></div><div class='flex flex-col gap-1.5'><label class='text-xs font-bold text-gray-600 dark:text-gray-400'>Password</label><input id='password' type='password' placeholder='••••••••' class='w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-all placeholder:text-gray-400 text-gray-900 dark:text-white text-sm' /></div><button onclick=\"Peera.auth.login('email', 'password')\" class='w-full py-3 bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-xl font-bold uppercase tracking-widest text-sm shadow-sm transition-all cursor-pointer mt-2'>Verify Credentials</button></div><div class='mt-8 pt-6 border-t border-gray-100 dark:border-gray-800 text-center'><p class='text-xs text-gray-400 dark:text-gray-500'>Protected by Peera Core Security</p></div></div></div><div class='hidden lg:flex flex-1 items-center justify-center bg-gray-900 dark:bg-gray-950 relative overflow-hidden'><div class='absolute inset-0 opacity-10' style=\"background-image: radial-gradient(#fff 0.5px, transparent 0.5px); background-size: 32px 32px;\"></div><div class='absolute bottom-0 left-0 w-full h-1/2 bg-gradient-to-t from-brand-500/10 to-transparent'></div><div class='relative z-10 text-center max-w-md p-10'><div class='mb-8 inline-flex items-center gap-2 px-3 py-1.5 bg-red-500/10 border border-red-500/20 rounded-full'><div class='w-2 h-2 bg-red-500 rounded-full animate-pulse'></div><span class='text-[10px] font-bold text-red-400 uppercase tracking-widest'>Admin Terminal</span></div><h2 class='text-4xl font-black text-white mb-4 tracking-tight leading-tight'>System<br/>Control Center</h2><p class='text-gray-400 text-sm font-medium leading-relaxed'>Manage tenants, billing, infrastructure, and system-wide configuration.</p></div></div></div>"
      },
      "admin/dashboard": {
        "title": "Admin Dashboard",
        "html": "<div class='p-6 lg:p-8 max-w-7xl mx-auto flex flex-col gap-8'><div class='flex flex-col gap-1'><h1 class='text-2xl font-black text-gray-900 dark:text-white tracking-tight'>Control Center</h1><p class='text-sm text-gray-500 dark:text-gray-400'>Infrastructure management and system overview.</p></div><div class='grid grid-cols-1 md:grid-cols-4 gap-5'><div class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] p-5 md:p-6 flex flex-col gap-3'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Total Tenants</span><h3 class='text-3xl font-black text-gray-900 dark:text-white'>1,284</h3></div><div class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] p-5 md:p-6 flex flex-col gap-3'><span class='text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>Active Nodes</span><h3 class='text-3xl font-black text-emerald-600 dark:text-emerald-400 font-mono'>99.9%</h3></div></div></div>"
      },
      "admin/theme": {
        "title": "Admin Theme Designer",
        "html": "<div class='min-h-screen bg-gray-50 dark:bg-gray-900 font-sans flex flex-col items-center justify-center p-8 lg:p-16 relative overflow-hidden'><div class='absolute inset-0 opacity-20 dark:opacity-10' style=\"background-image: radial-gradient(#94a3b8 0.5px, transparent 0.5px); background-size: 24px 24px;\"></div><div class='absolute top-0 left-0 w-[500px] h-[500px] bg-brand-500/5 blur-[100px] rounded-full -translate-x-1/2 -translate-y-1/2'></div><div class='w-full max-w-5xl relative z-10'><div class='flex flex-col gap-3 mb-14 text-center'><h1 class='text-5xl font-black text-gray-900 dark:text-white tracking-tight'>Theme Studio</h1><div class='h-1 w-24 bg-brand-500 mx-auto rounded-full mt-2'></div><p class='text-sm text-gray-500 dark:text-gray-400 mt-6'>Design and customize your customer portal experience.</p></div><div class='grid grid-cols-1 md:grid-cols-2 gap-6'><div class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] p-8 flex flex-col gap-6 hover:border-brand-500/50 transition-all group'><div class='w-12 h-12 bg-brand-500/10 rounded-xl flex items-center justify-center text-brand-500 group-hover:bg-brand-500 group-hover:text-white transition-all'><svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4'></path></svg></div><div class='flex flex-col gap-2'><h2 class='text-lg font-black text-gray-900 dark:text-white'>Live Engine</h2><p class='text-sm text-gray-500 dark:text-gray-400 leading-relaxed'>Inject dynamic schemas and validate your design in real-time.</p></div><button onclick='Peera.dev.toggle()' class='w-full py-3 bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-xl text-sm font-bold uppercase tracking-widest transition-all active:scale-95 cursor-pointer'>Start Engine</button></div><div class='rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-white/[0.03] p-8 flex flex-col gap-6 hover:border-brand-500/50 transition-all group'><div class='w-12 h-12 bg-brand-500/10 rounded-xl flex items-center justify-center text-brand-500 group-hover:bg-brand-500 group-hover:text-white transition-all'><svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'></path><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'></path></svg></div><div class='flex flex-col gap-2'><h2 class='text-lg font-black text-gray-900 dark:text-white'>Portal Preview</h2><p class='text-sm text-gray-500 dark:text-gray-400 leading-relaxed'>Preview the complete customer journey with the latest layout.</p></div><button onclick='Peera.dev.launch()' class='w-full py-3 bg-brand-500 hover:bg-brand-600 text-white rounded-xl text-sm font-bold uppercase tracking-widest transition-all active:scale-95 shadow-sm cursor-pointer'>Launch Portal</button></div></div><div class='mt-12 pt-8 border-t border-gray-200 dark:border-gray-800 flex justify-between items-center'><div class='flex items-center gap-3'><span class='relative flex w-2.5 h-2.5'><span class='animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75'></span><span class='relative inline-flex rounded-full w-2.5 h-2.5 bg-emerald-500'></span></span><span class='text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest'>System Online</span></div><span onclick='Peera.dev.toggle()' class='text-xs font-bold text-red-400 hover:text-red-500 cursor-pointer transition-colors uppercase tracking-widest'>Kill Switch</span></div></div></div>"
      }
    }
