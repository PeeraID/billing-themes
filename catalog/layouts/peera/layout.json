{
  "version": "1.0.0",
  "name": "Peera Default",
  "description": "Standard layout for all new tenants",
  "layout": {
    "nav": {
      "items": [
        { "id": "nav.home", "label": "Home", "url": "/" },
        { "id": "nav.status", "label": "Status", "url": "/status" },
        { "id": "nav.billing", "label": "Billing", "url": "/billing" },
        { "id": "nav.docs", "label": "Documents", "url": "/documents" },
        { "id": "nav.profile", "label": "Profile", "url": "/profile" },
        { "id": "nav.security", "label": "Security", "url": "/security/change-password" },
        { 
          "id": "nav.signout", 
          "label": "Sign Out", 
          "html": "<button onclick='window.dispatchEvent(new CustomEvent(`signout`))' class='w-full mt-4 bg-red-900/20 hover:bg-red-900/40 text-red-400 p-2 rounded-lg transition-colors text-sm font-medium'>Sign Out</button>" 
        }
      ]
    },
    "signout": {
      "script": "auth.logout"
    },
    "contents": {
      "dashboard": {
        "title": "Dashboard",
        "html": "<div class='p-8 bg-stone-900 border border-stone-800 rounded-xl'><h1 class='text-2xl font-bold text-white'>Dashboard</h1></div>"
      },
      "billing": {
        "title": "Billing",
        "html": "<div class='p-8 bg-stone-900 border border-stone-800 rounded-xl'><h1 class='text-2xl font-bold text-white'>Billing</h1></div>"
      },
      "login": {
        "title": "Sign In",
        "html": "<div class='flex justify-center items-center min-h-screen p-4'><div class='w-full max-w-sm p-8 bg-stone-900 border border-stone-800 rounded-xl shadow-lg flex flex-col gap-6'><h1 class='text-2xl font-bold text-white text-center'>Sign In to Peera Portal</h1><div><label class='block text-sm font-medium text-stone-400 mb-1'>Email</label><input type='email' placeholder='your@email.com' class='w-full p-3 bg-black border border-stone-700 rounded-lg text-white outline-none' /></div><div><label class='block text-sm font-medium text-stone-400 mb-1'>Password</label><input type='password' placeholder='••••••••' class='w-full p-3 bg-black border border-stone-700 rounded-lg text-white outline-none' /></div><button class='w-full py-3 bg-blue-600 text-white font-bold rounded-lg hover:bg-blue-700 transition'>Login</button><p class='text-sm text-center text-stone-500'>Don't have an account? <a href='/register' class='text-blue-400 hover:underline'>Register here</a></p></div></div>"
      }
    }
  },
  "theme": {
    "tokens": {
      "colors": {
        "brand-500": "#465fff",
        "stone-950": "#0c0c0c"
      }
    }
  }
}