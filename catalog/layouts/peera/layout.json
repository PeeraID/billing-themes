{
  "version": "1.0.0",
  "name": "Peera Default",
  "description": "Standard layout for all new tenants",
  "layout": {
    "nav": {
      "items": [
        { "id": "nav.home", "label": "Home", "url": "/" },
        { "id": "nav.status", "label": "Status", "url": "/status" },
        { "id": "nav.billing", "label": "Billing", "url": "/billing" },
        { "id": "nav.docs", "label": "Documents", "url": "/documents" },
        { "id": "nav.profile", "label": "Profile", "url": "/profile" },
        { "id": "nav.security", "label": "Security", "url": "/security/change-password" },
        { 
          "id": "nav.signout", 
          "label": "Sign Out", 
          "html": "<button onclick=\"Peera.auth.logout()\" class='w-full mt-4 bg-red-900/20 hover:bg-red-900/40 text-red-400 p-2 rounded-lg transition-colors text-sm font-medium'>Sign Out</button>" 
        }
      ]
    },
    "signout": {
      "script": "auth.logout"
    },
    "contents": {
      "dashboard": {
        "title": "Dashboard",
        "html": "<div class='p-8 bg-stone-900 border border-stone-800 rounded-xl'><h1 class='text-2xl font-bold text-white'>Dashboard</h1></div>"
      },
      "billing": {
        "title": "Billing",
        "html": "<div class='p-8 bg-stone-900 border border-stone-800 rounded-xl'><h1 class='text-2xl font-bold text-white'>Billing</h1></div>"
      },
      "login": {
        "title": "Sign In",
        "html": "<div class='flex min-h-screen bg-stone-950 font-sans overflow-hidden'><div class='w-full lg:w-[40%] flex flex-col justify-center p-12 lg:p-20 z-10 bg-stone-950 border-r border-stone-800/50 shadow-2xl'><div class='mb-10'><div class='inline-flex items-center gap-3 p-4 bg-white rounded-2xl shadow-sm'><div class='w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center text-white font-bold'>P</div><div class='flex flex-col'><span class='text-sm font-bold text-stone-900 leading-none'>Peera</span><span class='text-[10px] text-stone-500'>Billing & Network Management</span></div></div></div><div class='flex flex-col gap-2 mb-8'><h1 class='text-4xl font-bold text-white tracking-tight'>Sign In</h1><p class='text-stone-500 text-sm'>Sign in with your account credentials.</p></div><div class='flex flex-col gap-6'><div class='flex flex-col gap-2'><label for='email' class='text-xs font-bold text-stone-400 uppercase tracking-widest'>Email</label><input type='email' id='email' placeholder='name@company.com' class='w-full p-4 bg-stone-900 border border-stone-800 rounded-xl text-white placeholder-stone-700 outline-none focus:ring-2 focus:ring-brand-500/50 transition-all' /></div><div class='flex flex-col gap-2'><label for='password' class='text-xs font-bold text-stone-400 uppercase tracking-widest'>Password</label><input type='password' id='password' placeholder='••••••••' class='w-full p-4 bg-stone-900 border border-stone-800 rounded-xl text-white placeholder-stone-700 outline-none focus:ring-2 focus:ring-brand-500/50 transition-all' /></div><button onclick=\"Peera.auth.login('email', 'password')\" class='w-full py-4 bg-brand-500 hover:bg-brand-600 text-white font-bold rounded-xl shadow-lg shadow-brand-500/20 active:scale-[0.98] transition-all cursor-pointer mt-4'>Sign In</button></div><div class='mt-12 text-sm text-stone-500'>Copyright © 2026 Peera. All rights reserved.</div></div><div class='hidden lg:flex flex-1 relative items-center justify-center bg-black overflow-hidden'><div class='absolute inset-0 opacity-20' style='background-image: radial-gradient(#262626 1px, transparent 1px); background-size: 40px 40px;'></div><div class='relative z-20 flex flex-col items-center gap-6 text-center'><div class='w-20 h-20 bg-brand-500 rounded-3xl flex items-center justify-center text-4xl font-bold text-white shadow-2xl'>P</div><div class='flex flex-col gap-1'><h2 class='text-2xl font-bold text-white'>Peera Billing</h2><p class='text-stone-500 max-w-xs'>Empowering ISPs with seamless billing and automated network management.</p></div></div></div></div>"
      }
    }
  },
  "theme": {
    "tokens": {
      "colors": {
        "brand-500": "#465fff",
        "stone-950": "#0c0c0c",
        "stone-900": "#171717"
      }
    }
  }
}