{
  "version": "1.0.0",
  "name": "Peera Default",
  "description": "Standard production-grade layout. Fully aligned with Peera Dashboard architecture.",
  "layout": {
    "header": {
      "container_class": "sticky top-0 z-99999 flex w-full border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-900 lg:border-b h-16 lg:h-[72px]",
      "html": "<div class='flex items-center justify-between w-full lg:px-6'><div class='flex items-center justify-between w-full gap-2 px-3 py-3 border-b border-gray-200 dark:border-gray-800 sm:gap-4 lg:justify-normal lg:border-b-0 lg:px-0 lg:py-4'><button class='items-center justify-center w-10 h-10 text-gray-500 border-gray-200 rounded-lg z-99999 dark:border-gray-800 lg:flex dark:text-gray-400 lg:h-11 lg:w-11 lg:border'><svg width='16' height='12' viewBox='0 0 16 12' fill='none'><path fill-rule='evenodd' clip-rule='evenodd' d='M0.583252 1C0.583252 0.585788 0.919038 0.25 1.33325 0.25H14.6666C15.0808 0.25 15.4166 0.585786 15.4166 1C15.4166 1.41421 15.0808 1.75 14.6666 1.75L1.33325 1.75C0.919038 1.75 0.583252 1.41422 0.583252 1ZM0.583252 11C0.583252 10.5858 0.919038 10.25 1.33325 10.25L14.6666 10.25C15.0808 10.25 15.4166 10.5858 15.4166 11C15.4166 11.4142 15.0808 11.75 14.6666 11.75L1.33325 11.75C0.919038 11.75 0.583252 11.4142 0.583252 11ZM1.33325 5.25C0.919038 5.25 0.583252 5.58579 0.583252 6C0.583252 6.41421 0.919038 6.75 1.33325 6.75L7.99992 6.75C8.41413 6.75 8.74992 6.41421 8.74992 6C8.74992 5.58579 8.41413 5.25 7.99992 5.25L1.33325 5.25Z' fill='currentColor'/></svg></button></div><div class='hidden items-center justify-between w-full gap-4 px-5 py-4 lg:flex lg:justify-end lg:px-0'><div class='flex items-center gap-2'><span class='hidden rounded-full border border-blue-200 bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700 lg:inline-flex'>{{global.customer_status}}</span></div><div class='flex items-center gap-2 2xsm:gap-3'><button onclick='Peera.theme.toggle()' class='relative flex h-11 w-11 items-center justify-center rounded-full border border-gray-200 bg-white text-gray-500 transition-colors hover:bg-gray-100 dark:border-gray-800 dark:bg-gray-900 dark:text-gray-400 dark:hover:bg-gray-800'><svg class='dark:hidden block' width='20' height='20' viewBox='0 0 20 20' fill='none' stroke='currentColor' stroke-width='2'><path d='M10 15a5 5 0 100-10 5 5 0 000 10zM10 2v1M10 18v1M4.22 4.22l.71.71M15.07 15.07l.71.71M2 10h1M18 10h1M4.22 15.78l.71-.71M15.07 4.93l.71-.71'/></svg><svg class='hidden dark:block text-yellow-400' width='20' height='20' viewBox='0 0 20 20' fill='none' stroke='currentColor' stroke-width='2'><path d='M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z'/></svg></button><button class='relative flex h-11 w-11 items-center justify-center rounded-full border border-gray-200 bg-white text-gray-500 transition-colors hover:bg-gray-100 dark:border-gray-800 dark:bg-gray-900 dark:text-gray-400 dark:hover:bg-gray-800'><svg width='20' height='20' fill='currentColor' viewBox='0 0 20 20'><path fill-rule='evenodd' clip-rule='evenodd' d='M10.75 2.29248C10.75 1.87827 10.4143 1.54248 10 1.54248C9.58583 1.54248 9.25004 1.87827 9.25004 2.29248V2.83613C6.08266 3.20733 3.62504 5.9004 3.62504 9.16748V14.4591H3.33337C2.91916 14.4591 2.58337 14.7949 2.58337 15.2091C2.58337 15.6234 2.91916 15.9591 3.33337 15.9591H4.37504H15.625H16.6667C17.0809 15.9591 17.4167 15.6234 17.4167 15.2091C17.4167 14.7949 17.0809 14.4591 16.6667 14.4591H16.375V9.16748C16.375 5.9004 13.9174 3.20733 10.75 2.83613V2.29248ZM14.875 14.4591V9.16748C14.875 6.47509 12.6924 4.29248 10 4.29248C7.30765 4.29248 5.12504 6.47509 5.12504 9.16748V14.4591H14.875ZM8.00004 17.7085C8.00004 18.1228 8.33583 18.4585 8.75004 18.4585H11.25C11.6643 18.4585 12 18.1228 12 17.7085C12 17.2943 11.6643 16.9585 11.25 16.9585H8.75004C8.33583 16.9585 8.00004 17.2943 8.00004 17.7085Z' /></svg></button><div class='relative'><button class='flex items-center text-gray-700 dark:text-gray-400'><span class='mr-3 flex h-11 w-11 items-center justify-center rounded-full bg-brand-100 text-sm font-semibold text-brand-700'>{{global.customer_status[0]}}</span><span class='block mr-1 font-medium text-theme-sm'>{{profile.fullname}}</span><svg class='stroke-gray-500 dark:stroke-gray-400 transition-transform duration-200' width='18' height='20' viewBox='0 0 18 20' fill='none'><path d='M4.3125 8.65625L9 13.3437L13.6875 8.65625' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/></svg></button></div></div></div></div>"
    },
    "nav": {
      "container_class": "fixed top-16 left-0 z-50 flex h-[calc(100dvh-4rem)] flex-col overflow-hidden border-r border-gray-200 bg-white px-5 text-gray-900 transition-all duration-300 ease-in-out dark:border-gray-800 dark:bg-gray-900 lg:top-0 lg:h-screen w-[260px] -translate-x-full lg:translate-x-0",
      "header_html": "<div class='py-8 flex justify-start'><div class='flex items-center gap-3'><img alt='Peera' width='50' height='50' src='{{global.logo}}'><div><p class='text-base font-semibold leading-tight text-gray-900 dark:text-white'>{{global.company_name}}</p><p class='text-xs leading-tight text-gray-500 dark:text-gray-400'>Billing & Network System</p></div></div></div>",
      "groups": [
        {
          "title": "Overview",
          "items": [
            { "id": "nav.dashboard", "label": "Dashboard", "url": "/", "html": "<li><a class='flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors hover:bg-gray-50 dark:hover:bg-gray-800 text-gray-900 dark:text-gray-100 bg-gray-50 dark:bg-gray-800' href='/'><svg class='size-5' width='1em' height='1em' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z'/><polyline points='9 22 9 12 15 12 15 22'/></svg>Dashboard</a></li>" }
          ]
        },
        {
          "title": "Management",
          "items": [
            { "id": "nav.status", "label": "Status", "url": "/status", "html": "<li><a class='flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors hover:bg-gray-50 dark:hover:bg-gray-800 text-gray-600 dark:text-gray-400' href='/status'><svg class='size-5' width='1em' height='1em' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='22 12 18 12 15 21 9 3 6 12 2 12'/></svg>Status</a></li>" },
            { "id": "nav.billing", "label": "Billing", "url": "/billing", "html": "<li><a class='flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors hover:bg-gray-50 dark:hover:bg-gray-800 text-gray-600 dark:text-gray-400' href='/billing'><svg class='size-5' width='1em' height='1em' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='2' y='5' width='20' height='14' rx='2' ry='2'/><line x1='2' y1='10' x2='22' y2='10'/></svg>Billing</a></li>" },
            { "id": "nav.documents", "label": "Documents", "url": "/documents", "html": "<li><a class='flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors hover:bg-gray-50 dark:hover:bg-gray-800 text-gray-600 dark:text-gray-400' href='/documents'><svg class='size-5' width='1em' height='1em' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z'/><polyline points='14 2 14 8 20 8'/></svg>Documents</a></li>" },
            { "id": "nav.support", "label": "Support", "url": "/support", "html": "<li><a class='flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors hover:bg-gray-50 dark:hover:bg-gray-800 text-gray-600 dark:text-gray-400' href='/support'><svg class='size-5' width='1em' height='1em' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z'/></svg>Support</a></li>" }
          ]
        },
        {
          "title": "Account",
          "items": [
            { "id": "nav.profile", "label": "Profile", "url": "/profile", "html": "<li><a class='flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors hover:bg-gray-50 dark:hover:bg-gray-800 text-gray-600 dark:text-gray-400' href='/profile'><svg class='size-5' width='1em' height='1em' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2'/><circle cx='12' cy='7' r='4'/></svg>Profile</a></li>" }
          ]
        }
      ],
      "footer_html": "<div class='mt-auto p-4 border-t border-gray-200 dark:border-gray-800'><button onclick='Peera.auth.logout()' class='w-full flex items-center gap-3 px-4 py-2.5 text-gray-600 dark:text-gray-400 hover:text-red-600 transition-colors text-sm font-medium'><svg class='size-5' width='1em' height='1em' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4'/><polyline points='16 17 21 12 16 7'/><line x1='21' y1='12' x2='9' y2='12'/></svg>Logout</button></div>"
    },
    "contents": {
      "dashboard": { "title": "Dashboard", "html": "<div class='flex flex-col gap-6'><div class='flex flex-wrap items-center justify-between gap-3 mb-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Platform Dashboard</h2></div><div class='grid grid-cols-1 gap-4 md:grid-cols-3'><div class='overflow-hidden rounded-3xl border border-slate-200 bg-white p-5 shadow-sm transition-transform duration-200 hover:-translate-y-0.5 dark:bg-gray-800 dark:border-gray-700'><div class='-mx-5 -mt-5 mb-5 h-2 bg-brand-500'></div><p class='text-xs font-medium uppercase tracking-[0.18em] text-slate-500'>Legal Name</p><p class='mt-4 text-2xl font-semibold tracking-tight text-slate-950 dark:text-white'>{{profile.fullname}}</p></div><div class='overflow-hidden rounded-3xl border border-slate-200 bg-white p-5 shadow-sm transition-transform duration-200 hover:-translate-y-0.5 dark:bg-gray-800 dark:border-gray-700'><div class='-mx-5 -mt-5 mb-5 h-2 bg-emerald-500'></div><p class='text-xs font-medium uppercase tracking-[0.18em] text-slate-500'>Link Integrity</p><p class='mt-4 text-2xl font-semibold tracking-tight text-emerald-600 uppercase'>{{status.status}}</p></div><div class='overflow-hidden rounded-3xl border border-slate-200 bg-white p-5 shadow-sm transition-transform duration-200 hover:-translate-y-0.5 dark:bg-gray-800 dark:border-gray-700'><div class='-mx-5 -mt-5 mb-5 h-2 bg-amber-500'></div><p class='text-xs font-medium uppercase tracking-[0.18em] text-slate-500'>Financial Ledger</p><p class='mt-4 text-2xl font-semibold tracking-tight text-slate-950 dark:text-white tabular-nums'>{{global.currency}} {{billing.total_amount}}</p></div></div></div>" },
      "status": { "title": "Status", "html": "<div class='flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Network Status</h2><div class='bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-3xl p-8 grid grid-cols-2 gap-12 shadow-sm'><div class='flex flex-col gap-1'><span class='text-xs text-gray-500 font-bold uppercase'>Connection Status</span><span class='text-3xl font-bold text-emerald-600'>{{status.status}}</span></div><div class='flex flex-col gap-1'><span class='text-xs text-gray-500 font-bold uppercase'>Assigned IP</span><span class='text-2xl font-mono font-bold dark:text-white'>{{status.active_ip}}</span></div></div></div>" },
      "billing": { "title": "Billing", "html": "<div class='flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Billing Ledger</h2><div class='grid grid-cols-12 gap-6'><div class='col-span-8 p-10 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-3xl shadow-sm flex flex-col gap-8'><div class='flex flex-col gap-1'><span class='text-xs text-gray-500 font-bold uppercase'>Total Outstanding</span><span class='text-6xl font-bold text-gray-900 dark:text-white tabular-nums tracking-tighter'>{{global.currency}} {{billing.total_amount}}</span></div><button onclick='window.open(\"{{billing.payment_url}}\")' class='w-full py-4 bg-brand-500 hover:bg-brand-600 text-white rounded-xl font-bold text-sm shadow-lg'>Pay Now</button></div></div></div>" },
      "support": { "title": "Support", "html": "<div class='flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Support Center</h2><div class='bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-3xl p-10 flex flex-col gap-8'><div class='flex justify-between items-center'><div class='flex items-center gap-4'><span class='px-2.5 py-1 bg-brand-500 text-white rounded text-xs font-bold'>#{{support.ticket_number}}</span><h4 class='text-xl font-bold text-gray-900 dark:text-white uppercase'>{{support.title}}</h4></div><div class='text-indigo-600 text-[10px] font-bold uppercase tracking-widest'>{{support.status}}</div></div><p class='text-gray-500 text-base italic'>{{support.description}}</p></div></div>" },
      "documents": { "title": "Documents", "html": "<div class='flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Digital Archive</h2><div class='grid grid-cols-1 md:grid-cols-2 gap-6'><div class='p-8 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-3xl shadow-sm flex items-center justify-between group hover:border-brand-500 transition-all'><div class='flex items-center gap-6'><div class='w-14 h-14 bg-gray-50 dark:bg-gray-900 rounded-xl flex items-center justify-center text-gray-400 group-hover:text-brand-600 transition-colors'><svg width='28' height='28' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z'/><polyline points='14 2 14 8 20 8'/></svg></div><div class='flex flex-col gap-0.5'><span class='text-lg font-bold text-gray-900 dark:text-white uppercase tracking-tight'>{{documents.name}}</span><span class='text-[10px] text-gray-500 font-medium italic'>System Artifact &bull; PDF</span></div></div><a href='{{documents.file_url}}' target='_blank' class='px-6 py-2.5 bg-brand-500 hover:bg-brand-600 text-white rounded-xl text-xs font-bold shadow-lg transition-all'>Download</a></div></div></div>" },
      "profile": { "title": "Profile", "html": "<div class='flex flex-col gap-6'><h2 class='text-xl font-semibold text-gray-800 dark:text-white/90'>Profile Settings</h2><div class='bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-3xl p-12 flex flex-col gap-12 shadow-sm'><div class='grid grid-cols-2 gap-20'><div class='flex flex-col gap-10'><div class='flex flex-col gap-1'><span class='text-[10px] text-gray-400 font-bold uppercase'>Legal Name</span><span class='text-3xl font-bold text-gray-900 dark:text-white'>{{profile.fullname}}</span></div></div><div class='flex flex-col gap-10'><div class='flex flex-col gap-1'><span class='text-[10px] text-gray-400 font-bold uppercase'>Email Grid</span><span class='text-xl font-bold dark:text-white'>{{profile.email}}</span></div></div></div></div></div>" }
    },
    "theme": { "tokens": { "colors": { "brand-500": "#465fff", "stone-950": "#0c0c0c", "stone-900": "#171717" } } }
  }
}
