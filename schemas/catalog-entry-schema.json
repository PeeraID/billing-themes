{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://billing.themes/v1/catalog-entry-schema.json",
  "title": "LayoutCatalogEntry",
  "description": "Approved shared layout entry in catalog (R20-R26)",
  "type": "object",
  "properties": {
    "layout_key": {
      "type": "string",
      "pattern": "^src_[a-f0-9]{8}$",
      "description": "Family key: src_{sha8(canonical_url)} for layout family versioning"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "approved", "deprecated"]
    },
    "tenant_code": {
      "type": "string",
      "nullable": true
    },
    "layout_tree": {
      "$ref": "#/$defs/LayoutTree"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["layout_key", "name", "title", "status", "layout_tree", "created_at", "updated_at"],
  "$defs": {
    "LayoutTree": {
      "type": "object",
      "properties": {
        "screens": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "screen_id": {
                "type": "string"
              },
              "composition": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["shell", "screen"]
                  },
                  "zones": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "items": {
                          "type": "array",
                          "minItems": 1,
                          "items": {
                            "type": "object",
                            "properties": {
                              "item_ref": {
                                "type": "string"
                              },
                              "placement": {
                                "type": "object",
                                "properties": {
                                  "order": {
                                    "type": "integer"
                                  }
                                }
                              },
                              "visibility": {
                                "type": "object",
                                "properties": {
                                  "mode": {"type": "string"},
                                  "when": {"type": "string"},
                                  "hidden": {"type": "boolean"}
                                }
                              },
                              "interaction": {
                                "type": "object",
                                "properties": {
                                  "type": {
                                    "type": "string",
                                    "enum": ["local_ui_rule", "official_action", "proposal_action"]
                                  }
                                }
                              }
                            },
                            "required": ["item_ref"]
                          }
                        }
                      },
                      "required": ["id", "items"]
                    }
                  }
                },
                "required": ["type", "zones"]
              }
            },
            "required": ["screen_id", "composition"]
          }
        }
      },
      "required": ["screens"]
    }
  }
}
