{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://peera.id/schemas/layout-catalog-index.schema.json",
  "type": "object",
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["layout_key", "name", "latest_version"],
        "properties": {
          "layout_key": {
            "type": "string",
            "pattern": "^src_[a-f0-9]{8}$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "latest_version": {
            "type": "string",
            "pattern": "^v[0-9]{3}$"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_domain": {
            "type": "string"
          },
          "updated_at": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
