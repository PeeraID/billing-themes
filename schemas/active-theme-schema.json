{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://billing.themes/v1/active-theme-schema.json",
  "title": "ActiveTheme",
  "description": "Single active theme stored per tenant code (R13)",
  "type": "object",
  "properties": {
    "tenant_code": {
      "type": "string",
      "minLength": 1,
      "description": "Tenant identifier for this theme"
    },
    "layout": {
      "$ref": "#/definitions/LayoutTree"
    },
    "version": {
      "type": "string",
      "pattern": "^[a-f0-9]{8}$",
      "description": "SHA8 hash of canonical URL (key for random mode)"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp of last update"
    },
    "mode": {
      "type": "string",
      "enum": ["random", "explicit"],
      "description": "Random mode uses URL uniqueness; explicit uses version bump if layout.tree differs by hash"
    }
  },
  "required": ["tenant_code", "layout", "version", "updated_at", "mode"],
  "definitions": {
    "LayoutTree": {
      "type": "object",
      "properties": {
        "screens": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/LayoutScreen"
          }
        }
      },
      "required": ["screens"]
    },
    "LayoutScreen": {
      "type": "object",
      "properties": {
        "screen_id": {
          "type": "string",
          "minLength": 1
        },
        "composition": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["shell", "screen"]
            },
            "zones": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/definitions/LayoutZone"
              }
            }
          },
          "required": ["type", "zones"]
        }
      },
      "required": ["screen_id", "composition"]
    },
    "LayoutZone": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/LayoutItem"
          }
        }
      },
      "required": ["id", "items"]
    },
    "LayoutItem": {
      "type": "object",
      "properties": {
        "item_ref": {
          "type": "string",
          "minLength": 1
        },
        "placement": {
          "$ref": "#/definitions/LayoutPlacement"
        },
        "visibility": {
          "$ref": "#/definitions/LayoutVisibility"
        },
        "interaction": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["local_ui_rule", "official_action", "proposal_action"]
            }
          },
          "required": ["type"]
        }
      },
      "required": ["item_ref"]
    },
    "LayoutPlacement": {
      "type": "object",
      "properties": {
        "order": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "LayoutVisibility": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string"
        },
        "when": {
          "type": "string"
        },
        "hidden": {
          "type": "boolean"
        }
      }
    }
  }
}
