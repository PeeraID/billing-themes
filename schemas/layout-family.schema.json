{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://peera.id/schemas/layout-family.schema.json",
  "type": "object",
  "required": [
    "layout_key",
    "version",
    "name",
    "renderer_version",
    "source",
    "hash",
    "layout"
  ],
  "properties": {
    "layout_key": {
      "type": "string",
      "pattern": "^src_[a-f0-9]{8}$"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]{3}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "renderer_version": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string"
    },
    "source": {
      "type": "object",
      "required": ["mode", "url", "canonical_url", "domain"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["random", "explicit", "promoted_custom"]
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "canonical_url": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "hash": {
      "type": "object",
      "required": ["layout_tree_hash"],
      "properties": {
        "layout_tree_hash": {
          "type": "string",
          "pattern": "^sha256:.+$"
        }
      },
      "additionalProperties": false
    },
    "layout": {
      "type": "object",
      "required": ["screens"],
      "properties": {
        "screens": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["screen_id", "composition"],
            "properties": {
              "screen_id": {
                "type": "string",
                "minLength": 1
              },
              "composition": {
                "type": "object",
                "required": ["type", "zones"],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["shell", "screen"]
                  },
                  "zones": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["id", "items"],
                      "properties": {
                        "id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "items": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "required": ["item_ref"],
                            "properties": {
                              "item_ref": {
                                "type": "string",
                                "minLength": 1
                              },
                              "placement": {
                                "type": "object",
                                "properties": {
                                  "order": {
                                    "type": "integer"
                                  }
                                },
                                "additionalProperties": false
                              },
                              "visibility": {
                                "type": "object",
                                "properties": {
                                  "mode": {
                                    "type": "string",
                                    "enum": ["always", "hidden", "conditional"]
                                  },
                                  "when": {
                                    "type": "string"
                                  }
                                },
                                "additionalProperties": false
                              },
                              "animation": {
                                "type": "object",
                                "properties": {
                                  "enter": {
                                    "type": "string"
                                  },
                                  "exit": {
                                    "type": "string"
                                  }
                                },
                                "additionalProperties": false
                              },
                              "interaction": {
                                "type": "object"
                              }
                            },
                            "additionalProperties": false
                          }
                        }
                      },
                      "additionalProperties": false
                    }
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
