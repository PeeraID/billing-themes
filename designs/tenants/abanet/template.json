-10 h-10' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4'></path></svg></div><div class='flex flex-col gap-4'><h2 class='text-2xl font-black text-stone-950 dark:text-white uppercase tracking-widest'>Live Engine</h2><p class='text-sm text-stone-500 leading-relaxed font-medium'>Experience real-time UI orchestration. Inject dynamic schemas and validate your vision instantly.</p></div><button onclick='Peera.dev.toggle()' class='w-full py-6 bg-stone-950 dark:bg-white text-white dark:text-black rounded-[30px] text-[11px] font-black uppercase tracking-[0.3em] transition-all active:scale-95 shadow-2xl shadow-black/20 dark:shadow-white/10 hover:shadow-brand-500/20'>Initiate Engine</button></div></div><div class='group p-14 bg-white/40 dark:bg-white/5 backdrop-blur-2xl border border-stone-200 dark:border-white/10 rounded-[60px] hover:border-blue-500/40 transition-all duration-700 shadow-2xl shadow-black/5 dark:shadow-3xl relative overflow-hidden'><div class='absolute -bottom-10 -left-10 w-40 h-40 bg-blue-600/5 blur-3xl rounded-full group-hover:scale-150 transition-transform duration-1000'></div><div class='flex flex-col gap-10 relative z-10'><div class='w-20 h-20 bg-stone-100 dark:bg-blue-600/20 rounded-[28px] flex items-center justify-center text-stone-950 dark:text-blue-400 group-hover:-rotate-6 transition-all duration-500 shadow-xl shadow-black/5'><svg class='w-10 h-10' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'></path><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'></path></svg></div><div class='flex flex-col gap-4'><h2 class='text-2xl font-black text-stone-950 dark:text-white uppercase tracking-widest'>Portal Preview</h2><p class='text-sm text-stone-500 leading-relaxed font-medium'>Step into your customer's world. Preview the complete journey with the latest architectural layout.</p></div><button onclick='Peera.dev.launch()' class='w-full py-6 bg-blue-600 text-white rounded-[30px] text-[11px] font-black uppercase tracking-[0.3em] transition-all active:scale-95 shadow-2xl shadow-blue-600/30 hover:shadow-blue-600/50'>Launch Portal</button></div></div></div><div class='mt-24 pt-10 border-t border-stone-200 dark:border-white/10 flex justify-between items-center'><div class='flex items-center gap-4'><div class='w-2.5 h-2.5 bg-green-500 rounded-full animate-ping absolute'></div><div class='w-2.5 h-2.5 bg-green-500 rounded-full relative'></div><span class='text-[10px] font-black uppercase tracking-[0.3em] text-stone-950 dark:text-white opacity-40'>System Status: Verified</span></div><div class='flex gap-8'><span class='text-[9px] font-black uppercase tracking-[0.3em] text-stone-400 hover:text-stone-950 dark:hover:text-white cursor-pointer transition-colors'>Documentation</span><span onclick='Peera.dev.toggle()' class='text-[9px] font-black uppercase tracking-[0.3em] text-red-500/50 hover:text-red-500 cursor-pointer transition-colors'>Emergency Kill-Switch</span></div></div></div></div>"
