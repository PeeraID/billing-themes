{
  "tenant_code": "abanet",
  "template": "peera",
  "layout": "peera",
  "layout_overrides": {
    "version": "1.0.0",
    "name": "Peera Default",
    "description": "Standard layout for all new tenants",
    "layout": {
      "nav": {
        "position": "left",
        "header_html": "<div class='p-8 pb-4 flex flex-col gap-2'><div class='inline-flex items-center gap-2'><div class='w-6 h-6 bg-brand-500 rounded-lg flex items-center justify-center text-white font-black text-[10px] shadow-lg'>P</div><span class='font-black text-stone-900 dark:text-white uppercase tracking-widest text-[10px]'>{{company_name}}</span></div><div class='h-px w-full bg-stone-100 dark:bg-white/5 mt-4'></div></div>",
        "footer_html": "<div class='p-8 pt-4'><div class='h-px w-full bg-stone-100 dark:bg-white/5 mb-4'></div><p class='text-[8px] font-black text-stone-400 uppercase tracking-[0.2em] leading-relaxed'>{{company_name}} v1.0<br/>Secure Gateway Active</p></div>",
        "items": [
          {
            "id": "nav.home",
            "label": "Home",
            "url": "/"
          },
          {
            "id": "nav.status",
            "label": "Status",
            "url": "/status"
          },
          {
            "id": "nav.billing",
            "label": "Billing",
            "url": "/billing"
          },
          {
            "id": "nav.docs",
            "label": "Documents",
            "url": "/documents"
          },
          {
