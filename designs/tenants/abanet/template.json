          },
          {
            "id": "nav.signout",
            "label": "Sign Out",
            "html": "<div class='px-4 mt-4'><button onclick='Peera.auth.logout()' class='w-full bg-red-500/10 hover:bg-red-500 text-red-500 hover:text-white py-3 rounded-2xl transition-all text-xs font-black uppercase tracking-widest cursor-pointer'>Sign Out</button></div>"
          }
        ]
      },
      "signout": {
        "script": "auth.logout"
      },
      "contents": {
        "dashboard": {
          "title": "Dashboard",
          "html": "<div class=\"p-8 lg:p-12 max-w-7xl mx-auto flex flex-col gap-12\">\n  \n  <!-- Header Section -->\n  <div class=\"flex flex-col sm:flex-row justify-between items-start sm:items-end gap-6\">\n    <div class=\"flex flex-col gap-3\">\n      <div class=\"flex items-center gap-3\">\n        <span class=\"px-3 py-1 bg-stone-100 dark:bg-stone-800 text-stone-600 dark:text-stone-400 text-[10px] font-bold uppercase tracking-widest rounded-full\">\n          Dashboard\n        </span>\n        <span class=\"text-stone-400 dark:text-stone-600 text-sm font-medium\">\n          {{tenant_code}}\n        </span>\n      </div>\n      <h1 class=\"text-4xl lg:text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-stone-900 via-stone-700 to-stone-900 dark:from-white dark:via-stone-300 dark:to-white tracking-tight\">\n        Welcome, {{tenant_name_final}}\n      </h1>\n      <p class=\"text-stone-500 dark:text-stone-400 font-medium text-lg\">\n        Manage your subscription and connection details.\n      </p>\n    </div>\n    \n    <!-- Status Badge -->\n    <div class=\"relative group\">\n      <div class=\"absolute -inset-1 bg-emerald-500/20 rounded-2xl blur-lg group-hover:bg-emerald-500/30 transition-all duration-500\"></div>\n      <div class=\"relative flex items-center gap-2 bg-emerald-500/10 dark:bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 px-5 py-2.5 rounded-xl font-bold text-xs uppercase tracking-widest border border-emerald-500/30 dark:border-emerald-500/40\">\n        <span class=\"relative flex h-2 w-2\">\n          <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-75\"></span>\n          <span class=\"relative inline-flex rounded-full h-2 w-2 bg-emerald-500\"></span>\n        </span>\n        Status: Active\n      </div>\n    </div>\n  </div>\n\n  <!-- Stats Cards Grid -->\n  <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8\">\n    \n    <!-- Outstanding Balance Card -->\n    <div class=\"group relative p-8 bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-1 hover:border-stone-300 dark:hover:border-stone-700 overflow-hidden\">\n      <div class=\"absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-violet-500/5 to-transparent rounded-full -translate-y-16 translate-x-16\"></div>\n      <div class=\"relative\">\n        <div class=\"flex items-center gap-2 mb-4\">\n          <div class=\"p-2 bg-violet-100 dark:bg-violet-900/30 rounded-lg\">\n            <svg class=\"w-4 h-4 text-violet-600 dark:text-violet-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z\"></path>\n            </svg>\n          </div>\n          <p class=\"text-stone-500 dark:text-stone-400 text-[10px] font-black uppercase tracking-[0.2em]\">\n            Outstanding Balance\n          </p>\n        </div>\n        <h3 class=\"text-4xl lg:text-5xl font-black text-stone-950 dark:text-white tracking-tight\">\n          {{currency}} <span class=\"text-emerald-500\">0.00</span>\n        </h3>\n      </div>\n    </div>\n\n    <!-- Connection Speed Card (Featured) -->\n    <div class=\"group relative p-8 bg-gradient-to-br from-blue-600 via-blue-500 to-cyan-500 rounded-3xl shadow-xl hover:shadow-2xl hover:shadow-blue-500/25 transition-all duration-500 hover:-translate-y-1 overflow-hidden\">\n      <div class=\"absolute inset-0 bg-gradient-to-br from-white/10 to-transparent\"></div>\n      <div class=\"absolute top-0 right-0 w-40 h-40 bg-white/10 rounded-full -translate-y-20 translate-x-20\"></div>\n      <div class=\"absolute bottom-0 left-0 w-32 h-32 bg-white/5 rounded-full translate-y-16 -translate-x-16\"></div>\n      <div class=\"relative\">\n        <div class=\"flex items-center gap-2 mb-4\">\n          <div class=\"p-2 bg-white/20 backdrop-blur-sm rounded-lg\">\n            <svg class=\"w-4 h-4 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 10V3L4 14h7v7l9-11h-7z\"></path>\n            </svg>\n          </div>\n          <p class=\"text-white/80 text-[10px] font-black uppercase tracking-[0.2em]\">\n            Connection Speed\n          </p>\n        </div>\n        <h3 class=\"text-4xl lg:text-5xl font-black text-white tracking-tight\">\n          50 <span class=\"text-xl lg:text-2xl font-bold text-white/80\">Mbps</span>\n        </h3>\n      </div>\n    </div>\n\n    <!-- Billing Cycle Card -->\n    <div class=\"group relative p-8 bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-1 hover:border-stone-300 dark:hover:border-stone-700 overflow-hidden\">\n      <div class=\"absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-amber-500/5 to-transparent rounded-full -translate-y-16 translate-x-16\"></div>\n      <div class=\"relative\">\n        <div class=\"flex items-center gap-2 mb-4\">\n          <div class=\"p-2 bg-amber-100 dark:bg-amber-900/30 rounded-lg\">\n            <svg class=\"w-4 h-4 text-amber-600 dark:text-amber-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z\"></path>\n            </svg>\n          </div>\n          <p class=\"text-stone-500 dark:text-stone-400 text-[10px] font-black uppercase tracking-[0.2em]\">\n            Billing Cycle\n          </p>\n        </div>\n        <h3 class=\"text-4xl lg:text-5xl font-black text-stone-950 dark:text-white tracking-tight\">\n          Monthly\n        </h3>\n      </div>\n    </div>\n\n  </div>\n</div>"
        },
        "billing": {
          "title": "Billing",
          "html": "<div class='p-12 max-w-7xl mx-auto'><h1 class='text-3xl font-black text-stone-900 dark:text-white mb-8'>Billing History</h1><div class='p-20 border border-dashed border-stone-300 dark:border-stone-800 rounded-[40px] text-center text-stone-500 italic'>No invoices found for this account.</div></div>"
        },
        "status": {
          "title": "Status",
          "html": "<div class=\"min-h-screen bg-stone-50 dark:bg-stone-950 p-8 md:p-12 transition-colors duration-300\">\n  <div class=\"max-w-5xl mx-auto\">\n    \n    <!-- Header Section -->\n    <div class=\"flex items-center justify-between mb-10\">\n      <div>\n        <div class=\"flex items-center gap-3 mb-2\">\n          <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center shadow-lg shadow-emerald-500/25\">\n            <svg class=\"w-5 h-5 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\"/>\n            </svg>\n          </div>\n          <span class=\"text-xs font-bold uppercase tracking-widest text-emerald-600 dark:text-emerald-400 bg-emerald-500/10 px-3 py-1 rounded-full\">All Systems Normal</span>\n        </div>\n        <h1 class=\"text-3xl md:text-4xl font-black text-stone-900 dark:text-white tracking-tight\">Network Status</h1>\n        <p class=\"text-stone-500 dark:text-stone-400 mt-1\">Real-time infrastructure monitoring for {{company_name}}</p>\n      </div>\n      <div class=\"hidden md:block text-right\">\n        <p class=\"text-xs text-stone-400 dark:text-stone-500 uppercase tracking-wider font-semibold\">Tenant</p>\n        <p class=\"text-sm font-bold text-stone-700 dark:text-stone-300\">{{tenant_name_final}}</p>\n        <p class=\"text-xs text-stone-400 dark:text-stone-500 font-mono\">{{tenant_code}}</p>\n      </div>\n    </div>\n\n    <!-- Status Cards Grid -->\n    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n      \n      <!-- Main Infrastructure Card -->\n      <div class=\"group relative overflow-hidden rounded-3xl bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 p-8 shadow-xl shadow-stone-200/50 dark:shadow-stone-950/50 hover:shadow-2xl hover:shadow-emerald-500/10 transition-all duration-500\">\n        <div class=\"absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-emerald-500/10 to-transparent rounded-full blur-2xl group-hover:scale-150 transition-transform duration-700\"></div>\n        <div class=\"relative\">\n          <div class=\"flex items-start justify-between mb-6\">\n            <div class=\"w-14 h-14 rounded-2xl bg-gradient-to-br from-emerald-500 to-emerald-600 flex items-center justify-center shadow-lg shadow-emerald-500/30\">\n              <svg class=\"w-7 h-7 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01\"/>\n              </svg>\n            </div>\n            <div class=\"flex items-center gap-2\">\n              <span class=\"relative flex h-3 w-3\">\n                <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75\"></span>\n                <span class=\"relative inline-flex rounded-full h-3 w-3 bg-emerald-500\"></span>\n              </span>\n            </div>\n          </div>\n          <h3 class=\"text-xl font-bold text-stone-900 dark:text-white mb-1\">Main Infrastructure</h3>\n          <p class=\"text-xs font-black uppercase tracking-[0.2em] text-emerald-600 dark:text-emerald-400\">Operational</p>\n          <div class=\"mt-6 pt-6 border-t border-stone-100 dark:border-stone-800\">\n            <div class=\"flex items-center justify-between text-sm\">\n              <span class=\"text-stone-500 dark:text-stone-400\">Uptime</span>\n              <span class=\"font-bold text-stone-900 dark:text-white\">99.99%</span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Global Gateway Card -->\n      <div class=\"group relative overflow-hidden rounded-3xl bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 p-8 shadow-xl shadow-stone-200/50 dark:shadow-stone-950/50 hover:shadow-2xl hover:shadow-sky-500/10 transition-all duration-500\">\n        <div class=\"absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-sky-500/10 to-transparent rounded-full blur-2xl group-hover:scale-150 transition-transform duration-700\"></div>\n        <div class=\"relative\">\n          <div class=\"flex items-start justify-between mb-6\">\n            <div class=\"w-14 h-14 rounded-2xl bg-gradient-to-br from-sky-500 to-blue-600 flex items-center justify-center shadow-lg shadow-sky-500/30\">\n              <svg class=\"w-7 h-7 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z\"/>\n              </svg>\n            </div>\n            <div class=\"flex items-center gap-2\">\n              <span class=\"relative flex h-3 w-3\">\n                <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-sky-400 opacity-75\"></span>\n                <span class=\"relative inline-flex rounded-full h-3 w-3 bg-sky-500\"></span>\n              </span>\n            </div>\n          </div>\n          <h3 class=\"text-xl font-bold text-stone-900 dark:text-white mb-1\">Global Gateway</h3>\n          <p class=\"text-xs font-black uppercase tracking-[0.2em] text-sky-600 dark:text-sky-400\">Healthy</p>\n          <div class=\"mt-6 pt-6 border-t border-stone-100 dark:border-stone-800\">\n            <div class=\"flex items-center justify-between text-sm\">\n              <span class=\"text-stone-500 dark:text-stone-400\">Latency</span>\n              <span class=\"font-bold text-stone-900 dark:text-white\">12ms</span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n    </div>\n\n    <!-- Footer -->\n    <div class=\"mt-8 flex items-center justify-between text-xs text-stone-400 dark:text-stone-500\">\n      <p>Last updated: Just now</p>\n      <p class=\"font-mono\">{{tenant_code}} • {{currency}}</p>\n    </div>\n\n  </div>\n</div>"
        },
        "login": {
          "title": "Sign In",
          "html": "<div class='flex min-h-screen bg-stone-50 dark:bg-[#050505] font-sans overflow-hidden transition-colors duration-500 text-stone-900 dark:text-white relative'><div class='absolute inset-0 dark:hidden' style='background: radial-gradient(circle, transparent 20%, rgba(0,0,0,0.05) 100%); pointer-events: none;'></div><div class='w-full lg:w-[45%] flex flex-col justify-center items-center p-12 lg:p-20 z-20 bg-white dark:bg-[#050505] border-r border-stone-200 dark:border-white/5 shadow-2xl transition-all duration-500'><div class='w-full max-sm:px-4 max-w-sm relative'><button onclick='Peera.theme.toggle()' class='absolute -top-12 right-0 p-2 bg-stone-100 dark:bg-white/5 border border-stone-200 dark:border-white/10 rounded-xl hover:scale-110 transition-all cursor-pointer'><svg class='w-5 h-5 dark:hidden text-stone-600' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z'></path></svg><svg class='w-5 h-5 hidden dark:block text-yellow-400' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z'></path></svg></button><div class='mb-12'><div class='inline-flex items-center gap-3 p-4 bg-white rounded-2xl shadow-[0_25px_60px_-15px_rgba(0,0,0,0.3)] dark:shadow-[0_40px_100px_-20px_rgba(0,0,0,1)] border border-stone-100 dark:border-transparent scale-105 transition-all'><img src='{{logo}}' alt='{{company_name}}' class='w-9 h-9 object-contain' /><div class='flex flex-col text-left'><span class='text-sm font-black text-stone-900 leading-none'>{{company_name}}</span><span class='text-[10px] text-stone-500 font-medium tracking-tight uppercase mt-1'>Customer Portal</span></div></div></div><div class='flex flex-col gap-2 mb-8'><h1 class='text-3xl font-black tracking-tight text-stone-950 dark:text-white'>Sign In</h1><p class='text-stone-500 font-medium'>Access your dashboard and subscription.</p></div><div class='flex flex-col gap-5'><div class='flex flex-col gap-2'><label class='text-xs font-black uppercase tracking-widest text-stone-400 ml-1'>Email Address</label><input id='email' type='email' placeholder='name@company.com' class='w-full p-4 bg-stone-50 dark:bg-black/20 border border-stone-200 dark:border-white/5 rounded-2xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500/50 transition-all placeholder:text-stone-400' /></div><div class='flex flex-col gap-2'><label class='text-xs font-black uppercase tracking-widest text-stone-400 ml-1'>Password</label><input id='password' type='password' placeholder='••••••••' class='w-full p-4 bg-stone-50 dark:bg-black/20 border border-stone-200 dark:border-white/5 rounded-2xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500/50 transition-all placeholder:text-stone-400' /></div><button onclick=\"Peera.auth.login('email', 'password')\" class='w-full py-4.5 bg-brand-500 hover:bg-brand-600 text-white rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-brand-500/20 active:scale-[0.98] transition-all cursor-pointer mt-4'>Enter Portal</button></div><div class='mt-10 pt-8 border-t border-stone-100 dark:border-white/5 text-center'><p class='text-xs text-stone-400 font-medium'>Forgot your password? <a href='/forgot' class='text-brand-500 font-black hover:underline underline-offset-4 ml-1'>Reset here</a></p></div></div></div><div class='hidden lg:flex flex-1 items-center justify-center bg-stone-50 dark:bg-black relative overflow-hidden transition-all duration-500'><div class='absolute inset-0 opacity-40' style=\"background-image: radial-gradient(#3b82f6 0.5px, transparent 0.5px); background-size: 24px 24px;\"></div><div class='absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-500/10 blur-[120px] rounded-full'></div><div class='relative z-10 text-center max-w-lg p-12'><div class='w-20 h-20 bg-white dark:bg-white/5 rounded-3xl shadow-2xl flex items-center justify-center mx-auto mb-10 border border-white/10'><svg class='w-10 h-10 text-brand-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'></path></svg></div><h2 class='text-4xl font-black text-stone-950 dark:text-white mb-4 tracking-tighter leading-tight'>Seamless Network Management</h2><p class='text-stone-500 text-lg font-medium leading-relaxed'>The ultimate billing and network orchestration system for modern ISPs.</p></div></div></div>"
        },
        "admin/login": {
          "title": "Admin Sign In",
          "html": "<div class='flex min-h-screen bg-stone-50 dark:bg-[#050505] font-sans overflow-hidden transition-colors duration-500 text-stone-900 dark:text-white relative'><div class='absolute inset-0 dark:hidden' style='background: radial-gradient(circle, transparent 20%, rgba(0,0,0,0.05) 100%); pointer-events: none;'></div><div class='w-full lg:w-[45%] flex flex-col justify-center items-center p-12 lg:p-20 z-20 bg-white dark:bg-[#050505] border-r border-stone-200 dark:border-white/5 shadow-2xl transition-all duration-500'><div class='w-full max-w-sm relative'><button onclick='Peera.theme.toggle()' class='absolute -top-12 right-0 p-2 bg-stone-100 dark:bg-white/5 border border-stone-200 dark:border-white/10 rounded-xl hover:scale-110 transition-all cursor-pointer'><svg class='w-5 h-5 dark:hidden text-stone-600' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z'></path></svg><svg class='w-5 h-5 hidden dark:block text-yellow-400' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z'></path></svg></button><div class='mb-12'><div class='inline-flex items-center gap-3 p-4 bg-stone-900 rounded-2xl shadow-[0_25px_60px_-15px_rgba(0,0,0,0.5)] border border-white/10 scale-105 transition-all'><div class='w-9 h-9 bg-brand-500 rounded-xl flex items-center justify-center text-white font-black text-xl'>A</div><div class='flex flex-col text-left'><span class='text-sm font-black text-white leading-none tracking-tight'>Peera Admin</span><span class='text-[10px] text-stone-500 font-bold tracking-widest uppercase mt-1'>Internal Access</span></div></div></div><div class='flex flex-col gap-2 mb-8'><h1 class='text-3xl font-black tracking-tight text-white'>Control Access</h1><p class='text-stone-500 font-medium'>Administrator authentication required.</p></div><div class='flex flex-col gap-5'><div class='flex flex-col gap-2'><label class='text-xs font-black uppercase tracking-widest text-stone-400 ml-1'>Admin Email</label><input id='email' type='email' placeholder='admin@peera.id' class='w-full p-4 bg-black/20 border border-white/5 rounded-2xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500/50 transition-all placeholder:text-stone-400 text-white' /></div><div class='flex flex-col gap-2'><label class='text-xs font-black uppercase tracking-widest text-stone-400 ml-1'>Secure Key</label><input id='password' type='password' placeholder='••••••••' class='w-full p-4 bg-black/20 border border-white/5 rounded-2xl outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500/50 transition-all placeholder:text-stone-400 text-white' /></div><button onclick=\"Peera.auth.login('email', 'password')\" class='w-full py-4.5 bg-white text-black rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-white/5 active:scale-[0.98] transition-all cursor-pointer mt-4'>Verify Credentials</button></div><div class='mt-10 pt-8 border-t border-white/5 text-center'><p class='text-xs text-stone-500 font-medium'>Protected by Peera Core Security</p></div></div></div><div class='hidden lg:flex flex-1 items-center justify-center bg-black relative overflow-hidden'><div class='absolute inset-0 opacity-20' style=\"background-image: radial-gradient(#fff 0.5px, transparent 0.5px); background-size: 32px 32px;\"></div><div class='absolute bottom-0 left-0 w-full h-full bg-gradient-to-t from-brand-500/20 to-transparent'></div><div class='relative z-10 text-center max-w-lg p-12'><div class='mb-10 inline-flex items-center gap-2 px-4 py-2 bg-red-500/10 border border-red-500/20 rounded-full'><div class='w-2 h-2 bg-red-500 rounded-full animate-pulse'></div><span class='text-[10px] font-black text-red-500 uppercase tracking-widest'>Admin Terminal</span></div><h2 class='text-5xl font-black text-white mb-6 tracking-tighter leading-[0.9] uppercase italic'>System<br/>Orchestrator</h2><p class='text-stone-500 text-lg font-medium leading-relaxed'>Manage global infrastructure, tenants, and system-wide design schemas.</p></div></div></div>"
